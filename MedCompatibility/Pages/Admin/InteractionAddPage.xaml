<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    BackgroundColor="{StaticResource AppBackground}"
    Shell.NavBarIsVisible="False"
    Title="{Binding PageTitle}"
    x:Class="MedCompatibility.Pages.Admin.InteractionAddPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:controls="clr-namespace:MedCompatibility.Pages.Shared.Controls"
    xmlns:converters="clr-namespace:MedCompatibility.Converters"
    xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
    xmlns:vm="clr-namespace:MedCompatibility.ViewModels.Admin"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:IsNullConverter x:Key="IsNullConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <controls:BackgroundBubblesView
            BottomBubbleBounds="0.50, 0.98, 820, 820"
            RightBubbleBounds="0.92, 0.10, 520, 520"
            TopBubbleBounds="0.06, 0.42, 300, 300" />

        <Grid
            HorizontalOptions="{OnPlatform WinUI=Center,
                                           MacCatalyst=Center,
                                           Default=Fill}"
            MaximumWidthRequest="800"
            RowDefinitions="Auto, *"
            WidthRequest="{OnPlatform WinUI=800,
                                      MacCatalyst=800}">

            <controls:CustomHeader
                Grid.Row="0"
                Margin="20,20,20,10"
                Title="{Binding PageTitle}" />

            <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
                <VerticalStackLayout Padding="20,10,20,40" Spacing="24">

                    <Border
                        BackgroundColor="White"
                        Padding="24"
                        StrokeShape="RoundRectangle 24"
                        StrokeThickness="0">
                        <Border.Shadow>
                            <Shadow
                                Brush="Black"
                                Offset="0,6"
                                Opacity="0.05"
                                Radius="12" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="16">
                            <Label
                                FontAttributes="Bold"
                                FontSize="18"
                                Text="Конфликтующие вещества"
                                TextColor="{StaticResource Primary}" />

                            <VerticalStackLayout Spacing="6">
                                <Label
                                    FontSize="12"
                                    Text="Вещество 1 *"
                                    TextColor="{StaticResource TextSecondary}" />
                                <Border
                                    BackgroundColor="#F5F7FA"
                                    HeightRequest="48"
                                    Padding="12,0"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 14">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SelectSubstance1Command}" />
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Label
                                            FontSize="14"
                                            Text="{Binding Substance1.Name, TargetNullValue='Выберите вещество'}"
                                            TextColor="{StaticResource TextPrimary}"
                                            VerticalOptions="Center" />
                                        <Label
                                            Grid.Column="1"
                                            Opacity="0.6"
                                            Text="🔍"
                                            VerticalOptions="Center" />
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="6">
                                <Label
                                    FontSize="12"
                                    Text="Вещество 2 *"
                                    TextColor="{StaticResource TextSecondary}" />
                                <Border
                                    BackgroundColor="#F5F7FA"
                                    HeightRequest="48"
                                    Padding="12,0"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 14">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SelectSubstance2Command}" />
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Label
                                            FontSize="14"
                                            Text="{Binding Substance2.Name, TargetNullValue='Выберите вещество'}"
                                            TextColor="{StaticResource TextPrimary}"
                                            VerticalOptions="Center" />
                                        <Label
                                            Grid.Column="1"
                                            Opacity="0.6"
                                            Text="🔍"
                                            VerticalOptions="Center" />
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <Border
                        BackgroundColor="White"
                        Padding="24"
                        StrokeShape="RoundRectangle 24"
                        StrokeThickness="0">
                        <Border.Shadow>
                            <Shadow
                                Brush="Black"
                                Offset="0,6"
                                Opacity="0.05"
                                Radius="12" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="16">
                            <Label
                                FontAttributes="Bold"
                                FontSize="18"
                                Text="Параметры риска"
                                TextColor="{StaticResource Primary}" />

                            <VerticalStackLayout Spacing="6">
                                <Label
                                    FontSize="12"
                                    Text="Уровень риска *"
                                    TextColor="{StaticResource TextSecondary}" />
                                <Border
                                    HeightRequest="48"
                                    Padding="12,0"
                                    Style="{StaticResource MedInputContainer}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding OpenRiskPickerCommand}" />
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Label
                                            Text="{Binding SelectedRisk.Name, TargetNullValue='Выберите риск'}"
                                            TextColor="{StaticResource TextPrimary}"
                                            VerticalOptions="Center" />
                                        <Label
                                            FontSize="10"
                                            Grid.Column="1"
                                            Opacity="0.5"
                                            Text="▼"
                                            VerticalOptions="Center" />
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="6">
                                <Label
                                    FontSize="12"
                                    Text="Тип взаимодействия *"
                                    TextColor="{StaticResource TextSecondary}" />
                                <Border
                                    HeightRequest="48"
                                    Padding="12,0"
                                    Style="{StaticResource MedInputContainer}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding OpenTypePickerCommand}" />
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Label
                                            Text="{Binding SelectedType.Name, TargetNullValue='Выберите тип'}"
                                            TextColor="{StaticResource TextPrimary}"
                                            VerticalOptions="Center" />
                                        <Label
                                            FontSize="10"
                                            Grid.Column="1"
                                            Opacity="0.5"
                                            Text="▼"
                                            VerticalOptions="Center" />
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <Border
                        BackgroundColor="White"
                        Padding="24"
                        StrokeShape="RoundRectangle 24"
                        StrokeThickness="0">
                        <Border.Shadow>
                            <Shadow
                                Brush="Black"
                                Offset="0,6"
                                Opacity="0.05"
                                Radius="12" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="16">
                            <Label
                                FontAttributes="Bold"
                                FontSize="18"
                                Text="Описание"
                                TextColor="{StaticResource Primary}" />

                            <VerticalStackLayout Spacing="6">
                                <Label
                                    FontSize="12"
                                    Text="Эффект взаимодействия *"
                                    TextColor="{StaticResource TextSecondary}" />
                                <Border
                                    BackgroundColor="#F8FAFC"
                                    HeightRequest="110"
                                    Padding="10"
                                    Stroke="{StaticResource BorderLight}"
                                    StrokeShape="RoundRectangle 12">
                                    <Editor
                                        AutoSize="TextChanges"
                                        Placeholder="Что произойдет?"
                                        Text="{Binding CurrentInteraction.Description}" />
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="6">
                                <Label
                                    FontSize="12"
                                    Text="Рекомендация"
                                    TextColor="{StaticResource TextSecondary}" />
                                <Border
                                    BackgroundColor="#F8FAFC"
                                    HeightRequest="90"
                                    Padding="10"
                                    Stroke="{StaticResource BorderLight}"
                                    StrokeShape="RoundRectangle 12">
                                    <Editor
                                        AutoSize="TextChanges"
                                        Placeholder="Что делать?"
                                        Text="{Binding CurrentInteraction.Recommendation}" />
                                </Border>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <Button
                        Command="{Binding SaveCommand}"
                        CornerRadius="16"
                        FontAttributes="Bold"
                        HeightRequest="56"
                        Margin="0,0,0,20"
                        Style="{StaticResource PrimaryButton}"
                        Text="{Binding ButtonText}" />

                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Grid>
</ContentPage>