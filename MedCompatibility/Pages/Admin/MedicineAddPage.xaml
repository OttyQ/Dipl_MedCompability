<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    BackgroundColor="{StaticResource AppBackground}"
    Shell.NavBarIsVisible="False"
    Title="{Binding PageTitle}"
    x:Class="MedCompatibility.Pages.Admin.MedicineAddPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:controls="clr-namespace:MedCompatibility.Pages.Shared.Controls"
    xmlns:converters="clr-namespace:MedCompatibility.Converters"
    xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
    xmlns:models="clr-namespace:MedCompatibility.Models"
    xmlns:vm="clr-namespace:MedCompatibility.ViewModels.Admin"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:IsNullConverter x:Key="IsNullConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <controls:BackgroundBubblesView
            BottomBubbleBounds="0.95, 0.95, 780, 780"
            RightBubbleBounds="0.08, 0.10, 260, 260"
            TopBubbleBounds="0.85, 0.38, 420, 420" />

        <Grid
            HorizontalOptions="{OnPlatform WinUI=Center,
                                           MacCatalyst=Center,
                                           Default=Fill}"
            MaximumWidthRequest="800"
            RowDefinitions="Auto, *"
            WidthRequest="{OnPlatform WinUI=800,
                                      MacCatalyst=800}">

            <controls:CustomHeader
                Grid.Row="0"
                Margin="20,20,20,10"
                Title="{Binding PageTitle}" />

            <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
                <VerticalStackLayout Padding="20,10,20,40" Spacing="24">

                    <Border
                        BackgroundColor="White"
                        Padding="24"
                        StrokeShape="RoundRectangle 24"
                        StrokeThickness="0">
                        <Border.Shadow>
                            <Shadow
                                Brush="Black"
                                Offset="0,6"
                                Opacity="0.05"
                                Radius="12" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="16">
                            <Label
                                FontAttributes="Bold"
                                FontSize="18"
                                Text="Основная информация"
                                TextColor="{StaticResource Primary}" />

                            <VerticalStackLayout Spacing="6">
                                <Label
                                    FontSize="12"
                                    Text="Торговое название *"
                                    TextColor="{StaticResource TextSecondary}" />
                                <Border
                                    HeightRequest="48"
                                    Padding="12,0"
                                    Stroke="Transparent"
                                    StrokeThickness="1"
                                    Style="{StaticResource MedInputContainer}"
                                    x:Name="NameBorder">
                                    <Entry
                                        FontSize="15"
                                        Placeholder="Например: Терафлю"
                                        Text="{Binding NewMedicine.TradeName}" />
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="6">
                                <Label
                                    FontSize="12"
                                    Text="МНН (Международное название) *"
                                    TextColor="{StaticResource TextSecondary}" />
                                <Border
                                    HeightRequest="48"
                                    Padding="12,0"
                                    Stroke="Transparent"
                                    StrokeThickness="1"
                                    Style="{StaticResource MedInputContainer}"
                                    x:Name="MnnBorder">
                                    <Entry
                                        FontSize="15"
                                        Placeholder="Например: Парацетамол + Фенилэфрин..."
                                        Text="{Binding NewMedicine.INN}" />
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="6">
                                <Label
                                    FontSize="12"
                                    Text="Форма выпуска *"
                                    TextColor="{StaticResource TextSecondary}" />
                                <Border
                                    HeightRequest="48"
                                    Padding="12,0"
                                    Stroke="Transparent"
                                    StrokeThickness="1"
                                    Style="{StaticResource MedInputContainer}"
                                    x:Name="FormBorder">
                                    <Entry
                                        FontSize="15"
                                        Placeholder="Например: Порошок, Таблетки"
                                        Text="{Binding NewMedicine.Form}" />
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="6">
                                <Label
                                    FontSize="12"
                                    Text="Описание / Инструкция"
                                    TextColor="{StaticResource TextSecondary}" />
                                <Border
                                    BackgroundColor="#F8FAFC"
                                    HeightRequest="120"
                                    Padding="12"
                                    Stroke="{StaticResource BorderLight}"
                                    StrokeShape="RoundRectangle 16"
                                    StrokeThickness="1">
                                    <Editor
                                        AutoSize="TextChanges"
                                        BackgroundColor="Transparent"
                                        Placeholder="Введите описание..."
                                        Text="{Binding NewMedicine.Description}" />
                                </Border>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <Border
                        BackgroundColor="White"
                        Padding="24"
                        StrokeShape="RoundRectangle 24"
                        StrokeThickness="0">
                        <Border.Shadow>
                            <Shadow
                                Brush="Black"
                                Offset="0,6"
                                Opacity="0.05"
                                Radius="12" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="16">
                            <Label
                                FontAttributes="Bold"
                                FontSize="18"
                                Text="Идентификация"
                                TextColor="{StaticResource Primary}" />

                            <VerticalStackLayout Spacing="6">
                                <Label
                                    FontSize="12"
                                    Text="Штрихкод (GTIN) *"
                                    TextColor="{StaticResource TextSecondary}" />
                                <Grid ColumnDefinitions="*, 52" ColumnSpacing="12">
                                    <Border
                                        HeightRequest="48"
                                        Padding="12,0"
                                        Stroke="Transparent"
                                        StrokeThickness="1"
                                        Style="{StaticResource MedInputContainer}"
                                        x:Name="GtinBorder">
                                        <Entry
                                            FontSize="15"
                                            Keyboard="Numeric"
                                            Placeholder="Сканируйте или введите"
                                            Text="{Binding NewMedicine.GTIN}" />
                                    </Border>
                                    <material:ButtonView
                                        BackgroundColor="{StaticResource Surface}"
                                        Grid.Column="1"
                                        HeightRequest="48"
                                        Stroke="{StaticResource BorderLight}"
                                        StrokeShape="{RoundRectangle CornerRadius=14}"
                                        StrokeThickness="1"
                                        TappedCommand="{Binding ScanBarcodeCommand}">
                                        <Label
                                            FontSize="22"
                                            HorizontalOptions="Center"
                                            Text="📷"
                                            TextColor="{StaticResource TextPrimary}"
                                            VerticalOptions="Center" />
                                    </material:ButtonView>
                                </Grid>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="6">
                                <Label
                                    FontSize="12"
                                    Text="Производитель *"
                                    TextColor="{StaticResource TextSecondary}" />
                                <Grid ColumnDefinitions="*">
                                    <Border
                                        BackgroundColor="#F5F7FA"
                                        HeightRequest="48"
                                        Padding="12,0"
                                        Stroke="Transparent"
                                        StrokeShape="RoundRectangle 14"
                                        StrokeThickness="1"
                                        x:Name="ManufacturerBorder">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding OpenManufacturerPickerCommand}" />
                                        </Border.GestureRecognizers>
                                        <Grid>
                                            <Label
                                                FontSize="14"
                                                LineBreakMode="TailTruncation"
                                                Text="{Binding SelectedManufacturer.Name}"
                                                TextColor="{StaticResource TextPrimary}"
                                                VerticalOptions="Center" />
                                            <Label
                                                FontSize="14"
                                                IsVisible="{Binding SelectedManufacturer, Converter={StaticResource IsNullConverter}}"
                                                Text="Выберите или создайте производителя"
                                                TextColor="{StaticResource TextSecondary}"
                                                VerticalOptions="Center" />
                                            <Label
                                                FontSize="10"
                                                HorizontalOptions="End"
                                                Text="▼"
                                                TextColor="{StaticResource TextSecondary}"
                                                VerticalOptions="Center" />
                                        </Grid>
                                    </Border>
                                </Grid>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <Border
                        BackgroundColor="White"
                        Padding="24"
                        StrokeShape="RoundRectangle 24"
                        StrokeThickness="0">
                        <Border.Shadow>
                            <Shadow
                                Brush="Black"
                                Offset="0,6"
                                Opacity="0.05"
                                Radius="12" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="16">
                            <Grid ColumnDefinitions="*, Auto">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="18"
                                    Text="Активные вещества"
                                    TextColor="{StaticResource Primary}"
                                    VerticalOptions="Center" />
                                <Button
                                    Command="{Binding AddSubstanceCommand}"
                                    FontSize="13"
                                    Grid.Column="1"
                                    HeightRequest="38"
                                    Padding="16,0"
                                    Style="{StaticResource PrimaryButton}"
                                    Text="+ Добавить" />
                            </Grid>

                            <FlexLayout
                                AlignItems="Start"
                                Direction="Row"
                                JustifyContent="Start"
                                Wrap="Wrap">
                                <BindableLayout.ItemsSource>
                                    <Binding Path="AddedSubstances" />
                                </BindableLayout.ItemsSource>
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:activesubstance">
                                        <Border
                                            BackgroundColor="#E3F2FD"
                                            Margin="0,0,8,8"
                                            Padding="12,8"
                                            StrokeShape="RoundRectangle 16"
                                            StrokeThickness="0">
                                            <HorizontalStackLayout Spacing="8">
                                                <Label
                                                    FontSize="14"
                                                    Text="{Binding Name}"
                                                    TextColor="#1565C0"
                                                    VerticalOptions="Center" />
                                                <Label
                                                    FontAttributes="Bold"
                                                    FontSize="14"
                                                    Text="✕"
                                                    TextColor="#1565C0"
                                                    VerticalOptions="Center">
                                                    <Label.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MedicineAddViewModel}}, Path=RemoveSubstanceCommand}" CommandParameter="{Binding .}" />
                                                    </Label.GestureRecognizers>
                                                </Label>
                                            </HorizontalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </FlexLayout>

                            <Label
                                FontSize="13"
                                HorizontalOptions="Center"
                                IsVisible="False"
                                Opacity="0.85"
                                Text="Нет добавленных веществ"
                                TextColor="{StaticResource TextSecondary}">
                                <Label.Triggers>
                                    <DataTrigger
                                        Binding="{Binding AddedSubstances.Count}"
                                        TargetType="Label"
                                        Value="0">
                                        <Setter Property="IsVisible" Value="True" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </VerticalStackLayout>
                    </Border>

                    <Label
                        FontSize="14"
                        HorizontalOptions="Center"
                        IsVisible="False"
                        Margin="0,5"
                        Text="Заполните все обязательные поля"
                        TextColor="{StaticResource Error}"
                        x:Name="ErrorLabel" />

                    <Button
                        Clicked="OnSaveClicked"
                        CornerRadius="16"
                        FontAttributes="Bold"
                        FontSize="16"
                        HeightRequest="56"
                        Margin="0,0,0,20"
                        Style="{StaticResource PrimaryButton}"
                        Text="{Binding ButtonText}" />
                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Grid>
</ContentPage>