<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    Shell.NavBarIsVisible="False"
    Title="Системные логи"
    x:Class="MedCompatibility.Pages.Admin.SystemLogsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:controls="clr-namespace:MedCompatibility.Pages.Shared.Controls"
    xmlns:models="clr-namespace:MedCompatibility.Models"
    xmlns:vm="clr-namespace:MedCompatibility.ViewModels.Admin"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Grid>
        <!--  фон  -->
        <controls:BackgroundBubblesView />

        <!--  Контент  -->
        <Grid Padding="10" RowDefinitions="Auto, *">

            <!--  Верхняя часть  -->
            <VerticalStackLayout
                Grid.Row="0"
                HorizontalOptions="Fill"
                Spacing="15"
                WidthRequest="{OnPlatform WinUI='800',
                                          Default='-1'}">

                <VerticalStackLayout.HorizontalOptions>
                    <OnPlatform x:TypeArguments="LayoutOptions">
                        <On Platform="WinUI" Value="Center" />
                        <On Platform="Android,iOS" Value="Fill" />
                    </OnPlatform>
                </VerticalStackLayout.HorizontalOptions>

                <!--  1) Шапка  -->
                <controls:CustomHeader Margin="10,10,10,5" Title="Системные логи" />

                <!--  2) Инфо-панель: БД + ИИ  -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                    <!--  Карточка БД  -->
                    <Frame
                        Padding="16"
                        Style="{StaticResource MedCard}">
                        <VerticalStackLayout Spacing="6">
                            <Label
                                FontSize="22"
                                HorizontalOptions="Center"
                                Text="🗄️" />
                            <Label
                                FontAttributes="Bold"
                                FontSize="12"
                                HorizontalTextAlignment="Center"
                                Text="База данных"
                                TextColor="{StaticResource TextSecondary}" />
                            <Border
                                BackgroundColor="{Binding DbStatusColor}"
                                HorizontalOptions="Center"
                                Padding="10,5"
                                StrokeShape="RoundRectangle 8"
                                StrokeThickness="0">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="11"
                                    Text="{Binding DbStatusText}"
                                    TextColor="White" />
                            </Border>
                        </VerticalStackLayout>
                    </Frame>

                    <!--  Карточка ИИ  -->
                    <Frame
                        Grid.Column="1"
                        Padding="16"
                        Style="{StaticResource MedCard}">
                        <VerticalStackLayout Spacing="6">
                            <Label
                                FontSize="22"
                                HorizontalOptions="Center"
                                Text="🤖" />
                            <Label
                                FontAttributes="Bold"
                                FontSize="12"
                                HorizontalTextAlignment="Center"
                                Text="Нейросеть"
                                TextColor="{StaticResource TextSecondary}" />
                            <Border
                                BackgroundColor="{Binding AiStatusColor}"
                                HorizontalOptions="Center"
                                Padding="10,5"
                                StrokeShape="RoundRectangle 8"
                                StrokeThickness="0">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="11"
                                    Text="{Binding AiStatusText}"
                                    TextColor="White" />
                            </Border>
                            <Label
                                FontSize="11"
                                HorizontalTextAlignment="Center"
                                Text="{Binding AiLatency, StringFormat='Пинг: {0}'}"
                                TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <!--  Заголовок списка  -->
                <Label
                    FontAttributes="Bold"
                    FontSize="16"
                    Text="Последние события"
                    TextColor="{StaticResource TextPrimary}" />

            </VerticalStackLayout>

            <!--  3) Список логов  -->
            <RefreshView
                Command="{Binding LoadLogsCommand}"
                Grid.Row="1"
                IsRefreshing="{Binding IsBusy}"
                Margin="0,10,0,0">

                <CollectionView
                    HorizontalOptions="Fill"
                    ItemsSource="{Binding RecentLogs}"
                    WidthRequest="{OnPlatform WinUI='800',
                                              Default='-1'}">

                    <CollectionView.HorizontalOptions>
                        <OnPlatform x:TypeArguments="LayoutOptions">
                            <On Platform="WinUI" Value="Center" />
                            <On Platform="Android,iOS" Value="Fill" />
                        </OnPlatform>
                    </CollectionView.HorizontalOptions>

                    <CollectionView.EmptyView>
                        <VerticalStackLayout
                            HorizontalOptions="Center"
                            Spacing="10"
                            VerticalOptions="Center">
                            <Label
                                FontSize="40"
                                HorizontalOptions="Center"
                                Text="📭" />
                            <Label
                                HorizontalOptions="Center"
                                Text="Логов пока нет"
                                TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:SystemLog">
                            <Frame
                                Margin="0,0,0,10"
                                Padding="12"
                                Style="{StaticResource MedListCard}">

                                <Grid ColumnDefinitions="40,*,Auto" ColumnSpacing="12">

                                    <!--  Иконка по типу действия  -->
                                    <Border
                                        HeightRequest="40"
                                        HorizontalOptions="Start"
                                        StrokeShape="RoundRectangle 10"
                                        StrokeThickness="0"
                                        VerticalOptions="Start"
                                        WidthRequest="40">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BackgroundColor" Value="#E3F2FD" />
                                                <Style.Triggers>
                                                    <DataTrigger
                                                        Binding="{Binding Action}"
                                                        TargetType="Border"
                                                        Value="Auth">
                                                        <Setter Property="BackgroundColor" Value="#E8F5E9" />
                                                    </DataTrigger>
                                                    <DataTrigger
                                                        Binding="{Binding Level}"
                                                        TargetType="Border"
                                                        Value="Error">
                                                        <Setter Property="BackgroundColor" Value="#FFEBEE" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Label
                                            FontSize="18"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center">
                                            <Label.Style>
                                                <Style TargetType="Label">
                                                    <Setter Property="Text" Value="📋" />
                                                    <Style.Triggers>
                                                        <DataTrigger
                                                            Binding="{Binding Action}"
                                                            TargetType="Label"
                                                            Value="Auth">
                                                            <Setter Property="Text" Value="🔐" />
                                                        </DataTrigger>
                                                        <DataTrigger
                                                            Binding="{Binding Action}"
                                                            TargetType="Label"
                                                            Value="Scan">
                                                            <Setter Property="Text" Value="🔎" />
                                                        </DataTrigger>
                                                        <DataTrigger
                                                            Binding="{Binding Level}"
                                                            TargetType="Label"
                                                            Value="Error">
                                                            <Setter Property="Text" Value="⚠️" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Label.Style>
                                        </Label>
                                    </Border>

                                    <!--  Текст  -->
                                    <VerticalStackLayout
                                        Grid.Column="1"
                                        Spacing="2"
                                        VerticalOptions="Center">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="14"
                                            LineBreakMode="TailTruncation"
                                            Text="{Binding Action}"
                                            TextColor="{StaticResource TextPrimary}" />

                                        <Label
                                            FontSize="12"
                                            LineBreakMode="TailTruncation"
                                            Text="{Binding Message}"
                                            TextColor="{StaticResource TextSecondary}" />

                                        <Label
                                            FontSize="11"
                                            Opacity="0.7"
                                            Text="{Binding User.Login}"
                                            TextColor="{StaticResource Primary}" />
                                    </VerticalStackLayout>

                                    <!--  Время  -->
                                    <VerticalStackLayout
                                        Grid.Column="2"
                                        HorizontalOptions="End"
                                        Spacing="0"
                                        VerticalOptions="Center">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="14"
                                            HorizontalOptions="End"
                                            Text="{Binding Timestamp, StringFormat='{0:HH:mm}'}"
                                            TextColor="{StaticResource TextPrimary}" />
                                        <Label
                                            FontSize="11"
                                            HorizontalOptions="End"
                                            Opacity="0.85"
                                            Text="{Binding Timestamp, StringFormat='{0:dd.MM}'}"
                                            TextColor="{StaticResource TextSecondary}" />
                                    </VerticalStackLayout>

                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                </CollectionView>
            </RefreshView>
        </Grid>
    </Grid>
</ContentPage>
