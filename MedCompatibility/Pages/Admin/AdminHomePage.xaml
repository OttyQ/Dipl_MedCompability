<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MedCompatibility.Pages.Admin.AdminHomePage"
             Title="Администратор"
             BackgroundColor="{StaticResource AppBackground}"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <Grid Padding="20">
            <VerticalStackLayout Spacing="30"
                                 HorizontalOptions="Center"
                                 MaximumWidthRequest="800">

                <!-- 1) Шапка -->
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Панель управления" Style="{StaticResource HeaderLabel}"/>
                        <Label Text="Добро пожаловать, Администратор" Style="{StaticResource SubHeaderLabel}"/>
                    </VerticalStackLayout>

                    <!-- Нормальная кнопка выхода -->
                    <Border Grid.Column="1"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="1"
                            Stroke="#E6EAF0"
                            BackgroundColor="White"
                            Padding="14,8"
                            VerticalOptions="Start">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding LogoutCommand}"/>
                        </Border.GestureRecognizers>

                        <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                            <Label Text="⎋" FontSize="14" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center"/>
                            <Label Text="Выйти"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextSecondary}"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Border>
                </Grid>

                <!-- 2) Статистика -->
                <Frame Style="{StaticResource CardFrame}" Padding="30" Margin="0,10">
                    <Grid ColumnDefinitions="*,Auto,*">
                        <VerticalStackLayout Grid.Column="0" Spacing="5" HorizontalOptions="Center">
                            <Label Text="{Binding PatientsCount}"
                                   FontSize="36"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}"
                                   HorizontalOptions="Center"/>
                            <Label Text="Всего пациентов"
                                   FontSize="14"
                                   TextColor="{StaticResource TextSecondary}"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>

                        <BoxView Grid.Column="1"
                                 WidthRequest="1"
                                 Color="#E0E0E0"
                                 VerticalOptions="Fill"
                                 Margin="20,0"/>

                        <VerticalStackLayout Grid.Column="2" Spacing="5" HorizontalOptions="Center">
                            <Label Text="{Binding DoctorsCount}"
                                   FontSize="36"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Secondary}"
                                   HorizontalOptions="Center"/>
                            <Label Text="Активных врачей"
                                   FontSize="14"
                                   TextColor="{StaticResource TextSecondary}"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Grid>
                </Frame>
                

<!-- 3) Меню (Адаптивное) -->
<VerticalStackLayout Spacing="20" Margin="0,20,0,50">
    <Label Text="Разделы системы"
           Style="{StaticResource SubHeaderLabel}"
           FontAttributes="Bold"
           Margin="5,0"/>

    <Grid ColumnDefinitions="*,*"
          RowDefinitions="170,170"
          ColumnSpacing="15"
          RowSpacing="15"
          Padding="4"
          MaximumWidthRequest="640" 
          HorizontalOptions="Fill"> 

        <!-- Плитка 1: Пользователи -->
        <Grid Grid.Row="0" Grid.Column="0">
            <!-- 1. Визуал (Frame) -->
            <Frame Style="{StaticResource CardFrame}" Padding="16" HasShadow="True" VerticalOptions="Fill" HorizontalOptions="Fill">
                <Grid RowDefinitions="Auto,Auto,*" RowSpacing="0">
                    <Frame HeightRequest="40" WidthRequest="40" CornerRadius="12"
                           BackgroundColor="#E3F2FD" Padding="0" BorderColor="Transparent" HorizontalOptions="Start">
                        <Label Text="👥" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Frame>
                    <Label Grid.Row="1" Text="Пользователи" FontAttributes="Bold" FontSize="15" 
                           TextColor="{StaticResource TextPrimary}" Margin="0,10,0,2"/>
                    <Label Grid.Row="2" Text="Управление доступом" FontSize="11" 
                           TextColor="{StaticResource TextSecondary}" LineBreakMode="TailTruncation" MaxLines="2"/>
                </Grid>
            </Frame>
            <!-- 2. Кнопка-невидимка (Перехватывает нажатие) -->
            <Button BackgroundColor="Transparent" 
                    Command="{Binding GoToUsersCommand}"
                    CornerRadius="12"
                    BorderWidth="0"/>
        </Grid>

        <!-- Плитка 2: Справочник -->
        <Grid Grid.Row="0" Grid.Column="1">
            <Frame Style="{StaticResource CardFrame}" Padding="16" HasShadow="True" VerticalOptions="Fill" HorizontalOptions="Fill">
                <Grid RowDefinitions="Auto,Auto,*" RowSpacing="0">
                    <Frame HeightRequest="40" WidthRequest="40" CornerRadius="12"
                           BackgroundColor="#E8F5E9" Padding="0" BorderColor="Transparent" HorizontalOptions="Start">
                        <Label Text="💊" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Frame>
                    <Label Grid.Row="1" Text="Справочник" FontAttributes="Bold" FontSize="15" 
                           TextColor="{StaticResource TextPrimary}" Margin="0,10,0,2"/>
                    <Label Grid.Row="2" Text="База лекарств" FontSize="11" 
                           TextColor="{StaticResource TextSecondary}" LineBreakMode="TailTruncation" MaxLines="2"/>
                </Grid>
            </Frame>
            <Button BackgroundColor="Transparent" 
                    Command="{Binding GoToMedicinesCommand}"
                    CornerRadius="12"
                    BorderWidth="0"/>
        </Grid>

        <!-- Плитка 3: Конфликты -->
        <Grid Grid.Row="1" Grid.Column="0">
            <Frame Style="{StaticResource CardFrame}" Padding="16" HasShadow="True" VerticalOptions="Fill" HorizontalOptions="Fill">
                <Grid RowDefinitions="Auto,Auto,*" RowSpacing="0">
                    <Frame HeightRequest="40" WidthRequest="40" CornerRadius="12"
                           BackgroundColor="#FFF3E0" Padding="0" BorderColor="Transparent" HorizontalOptions="Start">
                        <Label Text="⚡" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Frame>
                    <Label Grid.Row="1" Text="Конфликты" FontAttributes="Bold" FontSize="15" 
                           TextColor="{StaticResource TextPrimary}" Margin="0,10,0,2"/>
                    <Label Grid.Row="2" Text="Правила совместимости" FontSize="11" 
                           TextColor="{StaticResource TextSecondary}" LineBreakMode="TailTruncation" MaxLines="2"/>
                </Grid>
            </Frame>
            <Button BackgroundColor="Transparent" 
                    Command="{Binding GoToConflictsCommand}"
                    CornerRadius="12"
                    BorderWidth="0"/>
        </Grid>

        <!-- Плитка 4: Система -->
        <Grid Grid.Row="1" Grid.Column="1">
            <Frame Style="{StaticResource CardFrame}" Padding="16" HasShadow="True" VerticalOptions="Fill" HorizontalOptions="Fill">
                <Grid RowDefinitions="Auto,Auto,*" RowSpacing="0">
                    <Frame HeightRequest="40" WidthRequest="40" CornerRadius="12"
                           BackgroundColor="#F3E5F5" Padding="0" BorderColor="Transparent" HorizontalOptions="Start">
                        <Label Text="⚙️" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Frame>
                    <Label Grid.Row="1" Text="Система" FontAttributes="Bold" FontSize="15" 
                           TextColor="{StaticResource TextPrimary}" Margin="0,10,0,2"/>
                    <Label Grid.Row="2" Text="Логи системы" FontSize="11" 
                           TextColor="{StaticResource TextSecondary}" LineBreakMode="TailTruncation" MaxLines="2"/>
                </Grid>
            </Frame>
            <Button BackgroundColor="Transparent" 
                    Command="{Binding GoToSystemCommand}"
                    CornerRadius="12"
                    BorderWidth="0"/>
        </Grid>

    </Grid>
</VerticalStackLayout>



            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>
