<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    Shell.NavBarIsVisible="False"
    x:Class="MedCompatibility.Pages.Admin.AdminHomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:controls="clr-namespace:MedCompatibility.Pages.Shared.Controls"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Grid>
        <controls:BackgroundBubblesView />

        <Grid
            HorizontalOptions="{OnPlatform WinUI=Center,
                                           MacCatalyst=Center,
                                           Default=Fill}"
            MaximumWidthRequest="800"
            WidthRequest="{OnPlatform WinUI=800,
                                      MacCatalyst=800}">

            <ScrollView VerticalScrollBarVisibility="Never">
                <VerticalStackLayout Padding="20,20,20,40" Spacing="24">

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                        <VerticalStackLayout Spacing="4">
                            <Label Style="{StaticResource HeaderLabel}" Text="Панель администратора" />
                            <Label Style="{StaticResource SubHeaderLabel}" Text="{Binding WelcomeMessage}" />
                        </VerticalStackLayout>
                        <Button
                            Command="{Binding LogoutCommand}"
                            Grid.Column="1"
                            Style="{StaticResource SecondaryButton}"
                            Text="Выйти"
                            VerticalOptions="Center" />
                    </Grid>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Border
                            BackgroundColor="{StaticResource Primary}"
                            Padding="18"
                            StrokeShape="RoundRectangle 18"
                            StrokeThickness="0">
                            <Border.Shadow>
                                <Shadow
                                    Brush="Black"
                                    Offset="0,4"
                                    Opacity="0.2"
                                    Radius="10" />
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="6">
                                <Label
                                    FontSize="13"
                                    Opacity="0.85"
                                    Text="Пациенты"
                                    TextColor="White" />
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="36"
                                    Text="{Binding PatientsCount}"
                                    TextColor="White" />
                            </VerticalStackLayout>
                        </Border>

                        <Border
                            BackgroundColor="{StaticResource Secondary}"
                            Grid.Column="1"
                            Padding="18"
                            StrokeShape="RoundRectangle 18"
                            StrokeThickness="0">
                            <Border.Shadow>
                                <Shadow
                                    Brush="Black"
                                    Offset="0,4"
                                    Opacity="0.2"
                                    Radius="10" />
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="6">
                                <Label
                                    FontSize="13"
                                    Opacity="0.85"
                                    Text="Врачи"
                                    TextColor="White" />
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="36"
                                    Text="{Binding DoctorsCount}"
                                    TextColor="White" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <Label
                        FontAttributes="Bold"
                        FontSize="20"
                        Margin="0,8,0,0"
                        Text="Быстрые действия"
                        TextColor="{StaticResource TextPrimary}" />

                    <Grid
                        ColumnDefinitions="*,*"
                        ColumnSpacing="15"
                        RowDefinitions="Auto,Auto"
                        RowSpacing="15">

                        <controls:ActionTile
                            Command="{Binding GoToUsersCommand}"
                            Description="Поиск, роли, статусы"
                            Grid.Column="0"
                            Grid.Row="0"
                            IconBackgroundColor="#2600796B"
                            IconText="👤"
                            Title="Пользователи" />

                        <controls:ActionTile
                            Command="{Binding GoToMedicinesCommand}"
                            Description="Каталог и производители"
                            Grid.Column="1"
                            Grid.Row="0"
                            IconBackgroundColor="#260097A7"
                            IconText="💊"
                            Title="Препараты" />

                        <controls:ActionTile
                            Command="{Binding GoToConflictsCommand}"
                            Description="Типы и уровни риска"
                            Grid.Column="0"
                            Grid.Row="1"
                            IconBackgroundColor="#26F9A825"
                            IconText="⚠"
                            Title="Взаимодействия" />

                        <controls:ActionTile
                            Command="{Binding GoToSystemCommand}"
                            Description="Логи и обслуживание"
                            Grid.Column="1"
                            Grid.Row="1"
                            IconBackgroundColor="#2678909C"
                            IconText="🛠"
                            Title="Система" />

                    </Grid>

                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Grid>
</ContentPage>