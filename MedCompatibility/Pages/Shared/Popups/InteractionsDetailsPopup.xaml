<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    CanBeDismissedByTappingOutsideOfPopup="True"
    Color="Transparent"
    x:Class="MedCompatibility.Pages.Shared.Popups.InteractionsDetailsPopup"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:models="clr-namespace:MedCompatibility.Models"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <toolkit:Popup.Resources>
        <ResourceDictionary>
            <Style TargetType="Border" x:Key="InteractionTypeBadgeStyle">
                <Setter Property="StrokeThickness" Value="1.5" />
                <Setter Property="Padding" Value="10,4" />
                <Setter Property="StrokeShape" Value="RoundRectangle 8" />
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="Stroke" Value="{StaticResource Primary}" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>

            <Style TargetType="Border" x:Key="RiskBadgeBorderStyle">
                <Setter Property="Margin" Value="0,0,8,8" />
                <Setter Property="Padding" Value="10,4" />
                <Setter Property="StrokeShape" Value="RoundRectangle 8" />
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="BackgroundColor" Value="#EEEEEE" />
                <Style.Triggers>
                    <DataTrigger
                        Binding="{Binding RiskLevel.Severity}"
                        TargetType="Border"
                        Value="1">
                        <Setter Property="BackgroundColor" Value="#E8F5E9" />
                    </DataTrigger>
                    <DataTrigger
                        Binding="{Binding RiskLevel.Severity}"
                        TargetType="Border"
                        Value="2">
                        <Setter Property="BackgroundColor" Value="#FFF3E0" />
                    </DataTrigger>
                    <DataTrigger
                        Binding="{Binding RiskLevel.Severity}"
                        TargetType="Border"
                        Value="3">
                        <Setter Property="BackgroundColor" Value="#FFF3E0" />
                    </DataTrigger>
                    <DataTrigger
                        Binding="{Binding RiskLevel.Severity}"
                        TargetType="Border"
                        Value="4">
                        <Setter Property="BackgroundColor" Value="#FFEBEE" />
                    </DataTrigger>
                    <DataTrigger
                        Binding="{Binding RiskLevel.Severity}"
                        TargetType="Border"
                        Value="5">
                        <Setter Property="BackgroundColor" Value="#FFEBEE" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="Label" x:Key="RiskLevelLabelStyle">
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="TextColor" Value="#424242" />
                <Style.Triggers>
                    <DataTrigger
                        Binding="{Binding RiskLevel.Severity}"
                        TargetType="Label"
                        Value="1">
                        <Setter Property="TextColor" Value="#2E7D32" />
                        <Setter Property="Text" Value="🟢 Незначительный риск" />
                    </DataTrigger>
                    <DataTrigger
                        Binding="{Binding RiskLevel.Severity}"
                        TargetType="Label"
                        Value="2">
                        <Setter Property="TextColor" Value="#F9A825" />
                        <Setter Property="Text" Value="🟡 Умеренный риск" />
                    </DataTrigger>
                    <DataTrigger
                        Binding="{Binding RiskLevel.Severity}"
                        TargetType="Label"
                        Value="3">
                        <Setter Property="TextColor" Value="#EF6C00" />
                        <Setter Property="Text" Value="🟠 Значительный риск" />
                    </DataTrigger>
                    <DataTrigger
                        Binding="{Binding RiskLevel.Severity}"
                        TargetType="Label"
                        Value="4">
                        <Setter Property="TextColor" Value="#D84315" />
                        <Setter Property="Text" Value="🔴 Высокий риск" />
                    </DataTrigger>
                    <DataTrigger
                        Binding="{Binding RiskLevel.Severity}"
                        TargetType="Label"
                        Value="5">
                        <Setter Property="TextColor" Value="#C62828" />
                        <Setter Property="Text" Value="🔴 Критический риск" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </toolkit:Popup.Resources>

    <Border
        BackgroundColor="{StaticResource Surface}"
        HorizontalOptions="Center"
        MaximumHeightRequest="650"
        MaximumWidthRequest="500"
        Padding="20"
        Stroke="{StaticResource Primary}"
        StrokeShape="RoundRectangle 20"
        StrokeThickness="1"
        VerticalOptions="Center">
        <Border.Shadow>
            <Shadow
                Brush="{StaticResource Primary}"
                Offset="0,4"
                Opacity="0.3"
                Radius="15" />
        </Border.Shadow>

        <Grid RowDefinitions="Auto, *, Auto" RowSpacing="16">

            <!--  Заголовок  -->
            <VerticalStackLayout Grid.Row="0" Spacing="8">
                <Label
                    FontAttributes="Bold"
                    FontSize="20"
                    HorizontalOptions="Center"
                    Text="⚠️ Обнаружены взаимодействия"
                    TextColor="{StaticResource TextPrimary}"
                    x:Name="TitleLabel" />
                <Label
                    FontSize="14"
                    HorizontalOptions="Center"
                    Text="Найдено взаимодействий"
                    TextColor="{StaticResource TextSecondary}"
                    x:Name="SubtitleLabel" />
            </VerticalStackLayout>

            <!--  Единый контент (Скролл)  -->
            <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
                <VerticalStackLayout Spacing="16">
                    <!--  Разделитель  -->
                    <BoxView Color="#E6EAF0" HeightRequest="1" />
                    <CollectionView SelectionMode="None" x:Name="InteractionsList">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout ItemSpacing="16" Orientation="Vertical" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <!-- Правка 3+4: DataTemplate привязан к ConflictCardModel -->
                        <DataTemplate x:DataType="models:ConflictCardModel">
                            <Border
                                BackgroundColor="{Binding CardBackgroundColor}"
                                Opacity="{Binding CardOpacity}"
                                StrokeShape="RoundRectangle 10"
                                StrokeThickness="0"
                                Padding="10">
                                <VerticalStackLayout Spacing="12">
                                    <!-- Правка 3: Заголовок типа конфликта (активное / остаточный) -->
                                    <HorizontalStackLayout Spacing="6">
                                        <Label
                                            FontSize="12"
                                            Text="{Binding ConflictTypeIcon}"
                                            VerticalOptions="Center" />
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="12"
                                            Text="{Binding ConflictTypeLabel}"
                                            TextColor="{StaticResource TextSecondary}"
                                            VerticalOptions="Center" />
                                    </HorizontalStackLayout>

                                    <!-- Правка 3: Подпись об остаточном эффекте (видима только если IsResidual=true) -->
                                    <Border
                                        IsVisible="{Binding IsResidual}"
                                        BackgroundColor="#FFF9C4"
                                        StrokeShape="RoundRectangle 6"
                                        StrokeThickness="0"
                                        Padding="8,4">
                                        <Label
                                            FontSize="11"
                                            FontAttributes="Italic"
                                            Text="{Binding ResidualLabel}"
                                            TextColor="#795548"
                                            LineBreakMode="WordWrap" />
                                    </Border>

                                    <!--  Верхняя часть: Вещества  -->
                                    <Grid ColumnDefinitions="*, Auto, *" ColumnSpacing="10">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="13"
                                            Grid.Column="0"
                                            HorizontalTextAlignment="Center"
                                            LineBreakMode="WordWrap"
                                            Text="{Binding SubstanceId1Navigation.Name}"
                                            TextColor="{StaticResource TextPrimary}" />

                                        <Label
                                            FontSize="20"
                                            Grid.Column="1"
                                            HorizontalOptions="Center"
                                            Text="⚡"
                                            TextColor="#E53935" />

                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="13"
                                            Grid.Column="2"
                                            HorizontalTextAlignment="Center"
                                            LineBreakMode="WordWrap"
                                            Text="{Binding SubstanceId2Navigation.Name}"
                                            TextColor="{StaticResource TextPrimary}" />
                                    </Grid>

                                    <!--  Инфо-плашки: уровень риска + тип  -->
                                    <FlexLayout Direction="Row" Wrap="Wrap">
                                        <Border Style="{StaticResource RiskBadgeBorderStyle}">
                                            <Label Style="{StaticResource RiskLevelLabelStyle}" />
                                        </Border>

                                        <VerticalStackLayout Margin="0,0,8,8" Spacing="2">
                                            <Border Style="{StaticResource InteractionTypeBadgeStyle}">
                                                <Label
                                                    FontAttributes="Bold"
                                                    FontSize="11"
                                                    Text="{Binding InteractionType.Name}"
                                                    TextColor="{StaticResource Primary}" />
                                            </Border>
                                            <!-- Правка 4: InteractionType.Description — клинический контекст -->
                                            <Label
                                                FontSize="12"
                                                LineBreakMode="WordWrap"
                                                Text="{Binding InteractionType.Description}"
                                                TextColor="{StaticResource TextSecondary}"
                                                IsVisible="{Binding InteractionType.Description, Converter={StaticResource StringNotNullOrEmptyConverter}}"
                                                Margin="4,0,0,0" />
                                        </VerticalStackLayout>
                                    </FlexLayout>

                                    <!--  Описание  -->
                                    <Label
                                        FontSize="13"
                                        LineBreakMode="WordWrap"
                                        Text="{Binding Description}"
                                        TextColor="{StaticResource TextPrimary}" />

                                    <!--  Рекомендация  -->
                                    <Border
                                        BackgroundColor="#F0F7F7"
                                        IsVisible="{Binding Recommendation, Converter={StaticResource StringNotNullOrEmptyConverter}}"
                                        Padding="12"
                                        StrokeShape="RoundRectangle 10">
                                        <Label
                                            FontAttributes="Italic"
                                            FontSize="13"
                                            LineBreakMode="WordWrap"
                                            Text="{Binding Recommendation}"
                                            TextColor="{StaticResource Primary}" />
                                    </Border>

                                    <!--  Разделитель между карточками  -->
                                    <BoxView
                                        Color="{StaticResource TextSecondary}"
                                        HeightRequest="1"
                                        Margin="0,5,0,0"
                                        Opacity="0.1" />
                                </VerticalStackLayout>
                            </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>


                    <!--  Подбор аналогов  -->
                    <VerticalStackLayout Spacing="8">
                        <BoxView Color="#E6EAF0" HeightRequest="1" />
                        
                        <Label Text="Подобрать безопасную замену" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource TextPrimary}" />
                        
                        <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto" RowSpacing="5" ColumnSpacing="5" Margin="0,10">
                            <CheckBox Grid.Row="0" Grid.Column="0" IsChecked="{Binding SearchOnlyBelarusian}" Color="{StaticResource Primary}" VerticalOptions="Center" />
                            <Label Grid.Row="0" Grid.Column="1" Text="Только производство РБ" VerticalOptions="Center" FontSize="12" TextColor="{StaticResource TextPrimary}" />
                            
                            <CheckBox Grid.Row="1" Grid.Column="0" IsChecked="{Binding SearchByATC}" Color="{StaticResource Primary}" VerticalOptions="Center" />
                            <Label Grid.Row="1" Grid.Column="1" Text="Искать терапевтические аналоги (АТХ)" VerticalOptions="Center" FontSize="12" TextColor="{StaticResource TextPrimary}" />
                        </Grid>
                        
                        <Button Text="Найти замену" Command="{Binding FindAlternativesCommand}" Style="{StaticResource PrimaryButton}" HeightRequest="40" Padding="0" />
                        
                        <ActivityIndicator IsRunning="{Binding IsSearchLoading}" IsVisible="{Binding IsSearchLoading}" Color="{StaticResource Primary}" HorizontalOptions="Center" Margin="0,10,0,0" />
                        
                        <CollectionView ItemsSource="{Binding SafeAlternatives}" IsVisible="{Binding HasAlternatives}" MaximumHeightRequest="160">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:medicine">
                                    <Border StrokeShape="RoundRectangle 8" Stroke="#E0E0E0" Padding="12" Margin="0,0,0,8" BackgroundColor="#FAFAFA">
                                        <VerticalStackLayout Spacing="4">
                                            <Label Text="{Binding TradeName}" FontAttributes="Bold" FontSize="14" TextColor="{StaticResource TextPrimary}" />
                                            <Label Text="{Binding INN}" FontSize="12" TextColor="{StaticResource TextSecondary}" />
                                            <HorizontalStackLayout Spacing="8">
                                                <Border IsVisible="{Binding ATCCode, Converter={StaticResource StringNotNullOrEmptyConverter}}" 
                                                        BackgroundColor="#E3F2FD" StrokeThickness="0" StrokeShape="RoundRectangle 4" Padding="4,2">
                                                    <Label Text="{Binding ATCCode}" FontSize="11" TextColor="{StaticResource Primary}" FontAttributes="Bold" />
                                                </Border>
                                                <Label Text="{Binding Manufacturer.Name}" FontSize="11" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </ScrollView>

            <!--  Кнопки  -->
            <Grid
                RowDefinitions="Auto"
                ColumnDefinitions="Auto, *, *"
                ColumnSpacing="10"
                Margin="0,10,0,0"
                Grid.Row="2">
                <Button
                    Command="{Binding ShareReportCommand}"
                    Grid.Column="0"
                    BackgroundColor="#E3F2FD"
                    TextColor="{StaticResource Primary}"
                    Text="📄"
                    FontAttributes="Bold"
                    FontSize="16"
                    WidthRequest="48"
                    HeightRequest="48"
                    CornerRadius="12"
                    Padding="0"
                    VerticalOptions="Center"
                    ToolTipProperties.Text="Сформировать PDF" />
                <Button
                    Clicked="OnCancelClicked"
                    Grid.Column="1"
                    Style="{StaticResource SecondaryButton}"
                    Text="Отменить"
                    Padding="5,0"
                    x:Name="CancelButton" />
                <Button
                    Clicked="OnContinueClicked"
                    Grid.Column="2"
                    Style="{StaticResource PrimaryButton}"
                    Text="Назначить"
                    Padding="5,0"
                    x:Name="ContinueButton" />
            </Grid>

        </Grid>
    </Border>
</toolkit:Popup>
