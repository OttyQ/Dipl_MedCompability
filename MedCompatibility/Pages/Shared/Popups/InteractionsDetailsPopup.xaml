<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    CanBeDismissedByTappingOutsideOfPopup="True"
    Color="Transparent"
    x:Class="MedCompatibility.Pages.Shared.Popups.InteractionsDetailsPopup"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:models="clr-namespace:MedCompatibility.Models"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <toolkit:Popup.Resources>
        <ResourceDictionary>
            <Style TargetType="Border" x:Key="InteractionTypeBadgeStyle">
                <Setter Property="StrokeThickness" Value="1.5" />
                <Setter Property="Padding" Value="10,4" />
                <Setter Property="StrokeShape" Value="RoundRectangle 8" />
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="Stroke" Value="{StaticResource Primary}" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>

            <Style TargetType="Border" x:Key="RiskBadgeBorderStyle">
                <Setter Property="Margin" Value="0,0,8,8" />
                <Setter Property="Padding" Value="10,4" />
                <Setter Property="StrokeShape" Value="RoundRectangle 8" />
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="BackgroundColor" Value="#EEEEEE" />
                <Style.Triggers>
                    <DataTrigger
                        Binding="{Binding RiskLevel.Severity}"
                        TargetType="Border"
                        Value="1">
                        <Setter Property="BackgroundColor" Value="#E8F5E9" />
                    </DataTrigger>
                    <DataTrigger
                        Binding="{Binding RiskLevel.Severity}"
                        TargetType="Border"
                        Value="2">
                        <Setter Property="BackgroundColor" Value="#FFF3E0" />
                    </DataTrigger>
                    <DataTrigger
                        Binding="{Binding RiskLevel.Severity}"
                        TargetType="Border"
                        Value="3">
                        <Setter Property="BackgroundColor" Value="#FFF3E0" />
                    </DataTrigger>
                    <DataTrigger
                        Binding="{Binding RiskLevel.Severity}"
                        TargetType="Border"
                        Value="4">
                        <Setter Property="BackgroundColor" Value="#FFEBEE" />
                    </DataTrigger>
                    <DataTrigger
                        Binding="{Binding RiskLevel.Severity}"
                        TargetType="Border"
                        Value="5">
                        <Setter Property="BackgroundColor" Value="#FFEBEE" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="Label" x:Key="RiskLevelLabelStyle">
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="TextColor" Value="#424242" />
                <Style.Triggers>
                    <DataTrigger
                        Binding="{Binding RiskLevel.Severity}"
                        TargetType="Label"
                        Value="1">
                        <Setter Property="TextColor" Value="#2E7D32" />
                        <Setter Property="Text" Value="🟢 Незначительный риск" />
                    </DataTrigger>
                    <DataTrigger
                        Binding="{Binding RiskLevel.Severity}"
                        TargetType="Label"
                        Value="2">
                        <Setter Property="TextColor" Value="#F9A825" />
                        <Setter Property="Text" Value="🟡 Умеренный риск" />
                    </DataTrigger>
                    <DataTrigger
                        Binding="{Binding RiskLevel.Severity}"
                        TargetType="Label"
                        Value="3">
                        <Setter Property="TextColor" Value="#EF6C00" />
                        <Setter Property="Text" Value="🟠 Значительный риск" />
                    </DataTrigger>
                    <DataTrigger
                        Binding="{Binding RiskLevel.Severity}"
                        TargetType="Label"
                        Value="4">
                        <Setter Property="TextColor" Value="#D84315" />
                        <Setter Property="Text" Value="🔴 Высокий риск" />
                    </DataTrigger>
                    <DataTrigger
                        Binding="{Binding RiskLevel.Severity}"
                        TargetType="Label"
                        Value="5">
                        <Setter Property="TextColor" Value="#C62828" />
                        <Setter Property="Text" Value="🔴 Критический риск" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </toolkit:Popup.Resources>

    <Border
        BackgroundColor="{StaticResource Surface}"
        HorizontalOptions="Center"
        MaximumHeightRequest="700"
        MaximumWidthRequest="500"
        Padding="20"
        Stroke="{StaticResource Primary}"
        StrokeShape="RoundRectangle 20"
        StrokeThickness="1"
        VerticalOptions="Center">
        <Border.Shadow>
            <Shadow
                Brush="{StaticResource Primary}"
                Offset="0,4"
                Opacity="0.3"
                Radius="15" />
        </Border.Shadow>

        <Grid RowDefinitions="Auto, Auto, *, Auto" RowSpacing="16">

            <!--  Заголовок  -->
            <VerticalStackLayout Grid.Row="0" Spacing="8">
                <Label
                    FontAttributes="Bold"
                    FontSize="20"
                    HorizontalOptions="Center"
                    Text="⚠️ Обнаружены взаимодействия"
                    TextColor="{StaticResource TextPrimary}"
                    x:Name="TitleLabel" />
                <Label
                    FontSize="14"
                    HorizontalOptions="Center"
                    Text="Найдено взаимодействий"
                    TextColor="{StaticResource TextSecondary}"
                    x:Name="SubtitleLabel" />
            </VerticalStackLayout>

            <!--  Разделитель  -->
            <BoxView
                Color="#E6EAF0"
                Grid.Row="1"
                HeightRequest="1" />

            <!--  Список взаимодействий  -->
            <ScrollView Grid.Row="2" VerticalScrollBarVisibility="Never">
                <CollectionView SelectionMode="None" x:Name="InteractionsList">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout ItemSpacing="16" Orientation="Vertical" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:interaction">
                            <VerticalStackLayout Spacing="12">
                                <!--  Верхняя часть: Препараты  -->
                                <Grid ColumnDefinitions="*, Auto, *" ColumnSpacing="10">
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="13"
                                        Grid.Column="0"
                                        HorizontalTextAlignment="Center"
                                        LineBreakMode="WordWrap"
                                        Text="{Binding SubstanceId1Navigation.Name}"
                                        TextColor="{StaticResource TextPrimary}" />

                                    <Label
                                        FontSize="20"
                                        Grid.Column="1"
                                        HorizontalOptions="Center"
                                        Text="⚡"
                                        TextColor="#E53935" />

                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="13"
                                        Grid.Column="2"
                                        HorizontalTextAlignment="Center"
                                        LineBreakMode="WordWrap"
                                        Text="{Binding SubstanceId2Navigation.Name}"
                                        TextColor="{StaticResource TextPrimary}" />
                                </Grid>

                                <!--  Инфо-плашки  -->
                                <FlexLayout Direction="Row" Wrap="Wrap">
                                    <Border Style="{StaticResource RiskBadgeBorderStyle}">
                                        <Label Style="{StaticResource RiskLevelLabelStyle}" />
                                    </Border>

                                    <Border Margin="0,0,0,8" Style="{StaticResource InteractionTypeBadgeStyle}">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="11"
                                            Text="{Binding InteractionType.Name}"
                                            TextColor="{StaticResource Primary}" />
                                    </Border>
                                </FlexLayout>

                                <!--  Описание  -->
                                <Label
                                    FontSize="13"
                                    LineBreakMode="WordWrap"
                                    Text="{Binding Description}"
                                    TextColor="{StaticResource TextPrimary}" />

                                <!--  Рекомендация (оформлена как в отчете)  -->
                                <Border
                                    BackgroundColor="#F0F7F7"
                                    IsVisible="{Binding Recommendation, Converter={StaticResource StringNotNullOrEmptyConverter}}"
                                    Padding="12"
                                    StrokeShape="RoundRectangle 10">
                                    <Label
                                        FontAttributes="Italic"
                                        FontSize="13"
                                        LineBreakMode="WordWrap"
                                        Text="{Binding Recommendation}"
                                        TextColor="{StaticResource Primary}" />
                                </Border>

                                <!--  Разделитель между карточками  -->
                                <BoxView
                                    Color="{StaticResource TextSecondary}"
                                    HeightRequest="1"
                                    Margin="0,5,0,0"
                                    Opacity="0.1" />
                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </ScrollView>

            <!--  Кнопки  -->
            <Grid
                ColumnDefinitions="Auto, *, *"
                ColumnSpacing="12"
                Grid.Row="3">
                <Button
                    Command="{Binding ShareReportCommand}"
                    Grid.Column="0"
                    BackgroundColor="#E3F2FD"
                    TextColor="{StaticResource Primary}"
                    Text="📄 PDF"
                    FontAttributes="Bold"
                    FontSize="14"
                    HeightRequest="48"
                    CornerRadius="12"
                    Padding="12,0"
                    VerticalOptions="Center"
                    ToolTipProperties.Text="Сформировать PDF" />
                <Button
                    Clicked="OnCancelClicked"
                    Grid.Column="1"
                    Style="{StaticResource SecondaryButton}"
                    Text="Отмена"
                    x:Name="CancelButton" />
                <Button
                    Clicked="OnContinueClicked"
                    Grid.Column="2"
                    Style="{StaticResource PrimaryButton}"
                    Text="Продолжить"
                    x:Name="ContinueButton" />
            </Grid>

        </Grid>
    </Border>
</toolkit:Popup>
