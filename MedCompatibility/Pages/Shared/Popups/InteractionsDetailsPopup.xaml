<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    CanBeDismissedByTappingOutsideOfPopup="True"
    Color="Transparent"
    x:Class="MedCompatibility.Pages.Shared.Popups.InteractionsDetailsPopup"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:models="clr-namespace:MedCompatibility.Models"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Border
        BackgroundColor="{StaticResource Surface}"
        HorizontalOptions="Center"
        MaximumHeightRequest="600"
        MaximumWidthRequest="450"
        Padding="20"
        Stroke="{StaticResource Primary}"
        StrokeShape="RoundRectangle 20"
        StrokeThickness="1"
        VerticalOptions="Center">
        <Border.Shadow>
            <Shadow
                Brush="{StaticResource Primary}"
                Offset="0,4"
                Opacity="0.3"
                Radius="15" />
        </Border.Shadow>

        <Grid RowDefinitions="Auto, Auto, *, Auto" RowSpacing="16">

            <!--  Заголовок  -->
            <VerticalStackLayout Grid.Row="0" Spacing="8">
                <Label
                    FontAttributes="Bold"
                    FontSize="20"
                    HorizontalOptions="Center"
                    Text="⚠️ Обнаружены взаимодействия"
                    TextColor="{StaticResource TextPrimary}"
                    x:Name="TitleLabel" />
                <Label
                    FontSize="14"
                    HorizontalOptions="Center"
                    Text="Найдено 3 взаимодействия"
                    TextColor="{StaticResource TextSecondary}"
                    x:Name="SubtitleLabel" />
            </VerticalStackLayout>

            <!--  Разделитель  -->
            <BoxView
                Color="#E6EAF0"
                Grid.Row="1"
                HeightRequest="1" />

            <!--  Список взаимодействий  -->
            <ScrollView Grid.Row="2">
                <CollectionView SelectionMode="None" x:Name="InteractionsList">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout ItemSpacing="12" Orientation="Vertical" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:interaction">
                            <Border
                                BackgroundColor="#F5F7FA"
                                Padding="12"
                                StrokeShape="RoundRectangle 12"
                                StrokeThickness="0">

                                <VerticalStackLayout Spacing="8">

                                    <!--  Препараты  -->
                                    <Grid ColumnDefinitions="*, Auto, *" ColumnSpacing="8">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="13"
                                            Grid.Column="0"
                                            HorizontalTextAlignment="End"
                                            LineBreakMode="TailTruncation"
                                            Text="{Binding SubstanceId1Navigation.Name}"
                                            TextColor="{StaticResource Primary}" />
                                        <Label
                                            FontSize="16"
                                            Grid.Column="1"
                                            Text="↔"
                                            TextColor="{StaticResource TextSecondary}" />
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="13"
                                            Grid.Column="2"
                                            LineBreakMode="TailTruncation"
                                            Text="{Binding SubstanceId2Navigation.Name}"
                                            TextColor="{StaticResource Primary}" />
                                    </Grid>

                                    <!--  Уровень риска  -->
                                    <Border
                                        HorizontalOptions="Start"
                                        Padding="8,4"
                                        StrokeShape="RoundRectangle 8">
                                        <Border.Triggers>
                                            <DataTrigger
                                                Binding="{Binding RiskLevel.Severity}"
                                                TargetType="Border"
                                                Value="1">
                                                <Setter Property="BackgroundColor" Value="#E8F5E9" />
                                            </DataTrigger>
                                            <DataTrigger
                                                Binding="{Binding RiskLevel.Severity}"
                                                TargetType="Border"
                                                Value="2">
                                                <Setter Property="BackgroundColor" Value="#FFF9C4" />
                                            </DataTrigger>
                                            <DataTrigger
                                                Binding="{Binding RiskLevel.Severity}"
                                                TargetType="Border"
                                                Value="3">
                                                <Setter Property="BackgroundColor" Value="#FFE0B2" />
                                            </DataTrigger>
                                            <DataTrigger
                                                Binding="{Binding RiskLevel.Severity}"
                                                TargetType="Border"
                                                Value="4">
                                                <Setter Property="BackgroundColor" Value="#FFCCBC" />
                                            </DataTrigger>
                                            <DataTrigger
                                                Binding="{Binding RiskLevel.Severity}"
                                                TargetType="Border"
                                                Value="5">
                                                <Setter Property="BackgroundColor" Value="#FFCDD2" />
                                            </DataTrigger>
                                        </Border.Triggers>

                                        <Label FontAttributes="Bold" FontSize="11">
                                            <Label.Triggers>
                                                <DataTrigger
                                                    Binding="{Binding RiskLevel.Severity}"
                                                    TargetType="Label"
                                                    Value="1">
                                                    <Setter Property="TextColor" Value="#2E7D32" />
                                                    <Setter Property="Text" Value="🟢 Незначительный риск" />
                                                </DataTrigger>
                                                <DataTrigger
                                                    Binding="{Binding RiskLevel.Severity}"
                                                    TargetType="Label"
                                                    Value="2">
                                                    <Setter Property="TextColor" Value="#F9A825" />
                                                    <Setter Property="Text" Value="🟡 Умеренный риск" />
                                                </DataTrigger>
                                                <DataTrigger
                                                    Binding="{Binding RiskLevel.Severity}"
                                                    TargetType="Label"
                                                    Value="3">
                                                    <Setter Property="TextColor" Value="#EF6C00" />
                                                    <Setter Property="Text" Value="🟠 Значительный риск" />
                                                </DataTrigger>
                                                <DataTrigger
                                                    Binding="{Binding RiskLevel.Severity}"
                                                    TargetType="Label"
                                                    Value="4">
                                                    <Setter Property="TextColor" Value="#D84315" />
                                                    <Setter Property="Text" Value="🔴 Высокий риск" />
                                                </DataTrigger>
                                                <DataTrigger
                                                    Binding="{Binding RiskLevel.Severity}"
                                                    TargetType="Label"
                                                    Value="5">
                                                    <Setter Property="TextColor" Value="#C62828" />
                                                    <Setter Property="Text" Value="🔴 Критический риск" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </Border>

                                    <!--  Описание  -->
                                    <Label
                                        FontSize="12"
                                        LineBreakMode="WordWrap"
                                        Text="{Binding Description}"
                                        TextColor="{StaticResource TextPrimary}" />

                                    <!--  Рекомендация  -->
                                    <Label
                                        FontSize="11"
                                        IsVisible="{Binding Recommendation, Converter={StaticResource StringNotNullOrEmptyConverter}}"
                                        LineBreakMode="WordWrap"
                                        Text="{Binding Recommendation}"
                                        TextColor="{StaticResource TextSecondary}" />

                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </ScrollView>

            <!--  Кнопки  -->
            <Grid
                ColumnDefinitions="*, *"
                ColumnSpacing="12"
                Grid.Row="3">
                <Button
                    Clicked="OnCancelClicked"
                    Grid.Column="0"
                    Style="{StaticResource SecondaryButton}"
                    Text="Отмена"
                    x:Name="CancelButton" />
                <Button
                    Clicked="OnContinueClicked"
                    Grid.Column="1"
                    Style="{StaticResource PrimaryButton}"
                    Text="Продолжить"
                    x:Name="ContinueButton" />
            </Grid>

        </Grid>
    </Border>
</toolkit:Popup>
