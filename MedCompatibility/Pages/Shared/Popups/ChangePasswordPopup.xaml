<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    CanBeDismissedByTappingOutsideOfPopup="False"
    Color="Transparent"
    x:Class="MedCompatibility.Pages.Shared.Popups.ChangePasswordPopup"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Border
        BackgroundColor="White"
        HorizontalOptions="Center"
        Padding="20"
        StrokeShape="RoundRectangle 20"
        StrokeThickness="0"
        VerticalOptions="Center"
        WidthRequest="350">

        <VerticalStackLayout Spacing="16">
            <Label
                FontAttributes="Bold"
                FontSize="20"
                HorizontalOptions="Center"
                Text="Смена пароля"
                TextColor="{StaticResource TextPrimary}" />

            <Border Style="{StaticResource MedInputContainer}">
                <Grid ColumnDefinitions="*,Auto">
                    <Entry
                        IsPassword="True"
                        Placeholder="Текущий пароль"
                        VerticalOptions="Center"
                        x:Name="OldPasswordEntry" />
                    <Button
                        BackgroundColor="Transparent"
                        Clicked="OnToggleOldPasswordClicked"
                        Grid.Column="1"
                        HeightRequest="44"
                        Padding="0"
                        Text="🙈"
                        TextColor="{StaticResource TextSecondary}"
                        WidthRequest="44"
                        x:Name="ToggleOldPasswordBtn" />
                </Grid>
            </Border>

            <Border Style="{StaticResource MedInputContainer}">
                <Grid ColumnDefinitions="*,Auto">
                    <Entry
                        IsPassword="True"
                        Placeholder="Новый пароль"
                        VerticalOptions="Center"
                        x:Name="NewPasswordEntry" />
                    <Button
                        BackgroundColor="Transparent"
                        Clicked="OnToggleNewPasswordClicked"
                        Grid.Column="1"
                        HeightRequest="44"
                        Padding="0"
                        Text="🙈"
                        TextColor="{StaticResource TextSecondary}"
                        WidthRequest="44"
                        x:Name="ToggleNewPasswordBtn" />
                </Grid>
            </Border>

            <Border Style="{StaticResource MedInputContainer}">
                <Grid ColumnDefinitions="*,Auto">
                    <Entry
                        IsPassword="True"
                        Placeholder="Подтверждение пароля"
                        VerticalOptions="Center"
                        x:Name="ConfirmPasswordEntry" />
                    <Button
                        BackgroundColor="Transparent"
                        Clicked="OnToggleConfirmPasswordClicked"
                        Grid.Column="1"
                        HeightRequest="44"
                        Padding="0"
                        Text="🙈"
                        TextColor="{StaticResource TextSecondary}"
                        WidthRequest="44"
                        x:Name="ToggleConfirmPasswordBtn" />
                </Grid>
            </Border>

            <Label
                FontSize="12"
                IsVisible="False"
                TextColor="{StaticResource Error}"
                x:Name="ErrorLabel" />

            <Grid ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,10,0,0">
                <Button
                    BackgroundColor="Transparent"
                    Clicked="OnCancelClicked"
                    Grid.Column="0"
                    Style="{StaticResource SecondaryButton}"
                    Text="Отмена" />
                <Button
                    Clicked="OnSaveClicked"
                    Grid.Column="1"
                    Style="{StaticResource PrimaryButton}"
                    Text="Сохранить" />
            </Grid>
        </VerticalStackLayout>
    </Border>
</toolkit:Popup>
