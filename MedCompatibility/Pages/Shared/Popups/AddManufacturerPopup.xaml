<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    CanBeDismissedByTappingOutsideOfPopup="False"
    Color="Transparent"
    x:Class="MedCompatibility.Pages.Shared.Popups.AddManufacturerPopup"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Border
        BackgroundColor="White"
        Padding="0"
        Shadow="{Shadow Brush=Black,
                        Offset='0,5',
                        Radius=15,
                        Opacity=0.2}"
        Stroke="{StaticResource Primary}"
        StrokeShape="RoundRectangle 20"
        StrokeThickness="1"
        VerticalOptions="Center"
        WidthRequest="320">

        <VerticalStackLayout Spacing="0">

            <!--  Заголовок  -->
            <Label
                FontAttributes="Bold"
                FontSize="18"
                HorizontalOptions="Center"
                Padding="20,20,20,10"
                Text="Новый производитель"
                TextColor="#1F2937" />

            <VerticalStackLayout Padding="20" Spacing="12">
                <!--  Название  -->
                <Border
                    BackgroundColor="#F3F4F6"
                    HeightRequest="48"
                    Padding="12,0"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="0">
                    <Entry
                        FontSize="14"
                        Placeholder="Название завода *"
                        PlaceholderColor="#9CA3AF"
                        TextChanged="OnTextChanged"
                        TextColor="#1F2937"
                        VerticalOptions="Center"
                        x:Name="NameEntry" />
                </Border>

                <Border
                    BackgroundColor="#F3F4F6"
                    HeightRequest="48"
                    Padding="12,0"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="0">
                    <Grid>
                        <Label
                            FontSize="14"
                            HorizontalOptions="Start"
                            LineBreakMode="TailTruncation"
                            Margin="0,0,25,0"
                            Text="{Binding Source={x:Reference CountryPicker}, Path=SelectedItem}"
                            TextColor="#1F2937"
                            VerticalOptions="Center" />

                        <!--  2. Иконка стрелочки  -->
                        <Label
                            FontSize="10"
                            HorizontalOptions="End"
                            Text="▼"
                            TextColor="#6B7280"
                            VerticalOptions="Center" />

                        <!--  3. Невидимый Picker, который ловит нажатия  -->
                        <Picker
                            HorizontalOptions="Fill"
                            Opacity="0"
                            Title="Выберите страну"
                            VerticalOptions="Fill"
                            x:Name="CountryPicker">
                            <Picker.ItemsSource>
                                <x:Array Type="{x:Type x:String}">
                                    <x:String>Республика Беларусь</x:String>
                                    <x:String>Россия</x:String>
                                    <x:String>Германия</x:String>
                                    <x:String>Индия</x:String>
                                    <x:String>Китай</x:String>
                                </x:Array>
                            </Picker.ItemsSource>
                        </Picker>
                    </Grid>
                </Border>

                <!--  Город  -->
                <Border
                    BackgroundColor="#F3F4F6"
                    HeightRequest="48"
                    Padding="12,0"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="0">
                    <Entry
                        FontSize="14"
                        Placeholder="Город"
                        PlaceholderColor="#9CA3AF"
                        TextColor="#1F2937"
                        VerticalOptions="Center"
                        x:Name="CityEntry" />
                </Border>

                <!--  Описание  -->
                <Border
                    BackgroundColor="#F3F4F6"
                    HeightRequest="80"
                    Padding="12,8"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="0">
                    <Editor
                        AutoSize="TextChanges"
                        BackgroundColor="Transparent"
                        FontSize="14"
                        Placeholder="Описание (опционально)"
                        PlaceholderColor="#9CA3AF"
                        TextColor="#1F2937"
                        x:Name="DescEntry" />
                </Border>
            </VerticalStackLayout>

            <!--  Кнопки  -->
            <Grid
                ColumnDefinitions="*, *"
                ColumnSpacing="12"
                Padding="20,0,20,20">
                <Button
                    BackgroundColor="White"
                    BorderColor="#D1D5DB"
                    BorderWidth="1"
                    Clicked="OnCancelClicked"
                    CornerRadius="8"
                    FontSize="14"
                    Grid.Column="0"
                    HeightRequest="44"
                    Text="Отмена"
                    TextColor="#4B5563" />

                <Button
                    BackgroundColor="{StaticResource Primary}"
                    Clicked="OnSaveClicked"
                    CornerRadius="8"
                    FontAttributes="Bold"
                    FontSize="14"
                    Grid.Column="1"
                    HeightRequest="44"
                    IsEnabled="False"
                    Opacity="0.5"
                    Text="Создать"
                    TextColor="White"
                    x:Name="CreateBtn" />
            </Grid>
        </VerticalStackLayout>
    </Border>
</toolkit:Popup>
