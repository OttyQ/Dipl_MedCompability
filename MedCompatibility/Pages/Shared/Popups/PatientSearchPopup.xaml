<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    CanBeDismissedByTappingOutsideOfPopup="False"
    Color="Transparent"
    HorizontalOptions="Center"
    Opened="OnPopupOpened"
    VerticalOptions="Center"
    x:Class="MedCompatibility.Pages.Shared.Popups.PatientSearchPopup"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:models="clr-namespace:MedCompatibility.Models"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Border
        BackgroundColor="White"
        HeightRequest="500"
        Padding="20"
        StrokeShape="RoundRectangle 20"
        StrokeThickness="0"
        WidthRequest="350">

        <Grid RowDefinitions="Auto, Auto, Auto, *, Auto" RowSpacing="12">

            <Label
                FontAttributes="Bold"
                FontSize="20"
                Grid.Row="0"
                Text="Добавить пациента"
                TextColor="Black" />

            <SearchBar
                BackgroundColor="#F0F0F0"
                Grid.Row="1"
                Placeholder="Фамилия или логин..."
                TextChanged="OnSearchTextChanged"
                x:Name="SearchInput" />

            <ActivityIndicator
                Color="#2563EB"
                Grid.Row="2"
                HeightRequest="24"
                IsRunning="False"
                IsVisible="False"
                x:Name="Loader" />

            <CollectionView
                Grid.Row="3"
                SelectionChanged="OnSelectionChanged"
                SelectionMode="Single"
                x:Name="ResultsList">
                <CollectionView.EmptyView>
                    <Label
                        HorizontalOptions="Center"
                        Text="Пациенты не найдены"
                        TextColor="#999"
                        VerticalOptions="Center" />
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:user">
                        <Border
                            BackgroundColor="#F5F5F5"
                            Margin="0,0,0,8"
                            Padding="12"
                            StrokeShape="RoundRectangle 10"
                            StrokeThickness="0">
                            <VerticalStackLayout Spacing="2">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="16"
                                    Text="{Binding LastName}"
                                    TextColor="Black" />
                                <Label
                                    FontSize="14"
                                    Text="{Binding FirstName}"
                                    TextColor="Gray" />
                                <Label
                                    FontSize="12"
                                    Text="{Binding Login, StringFormat='@{0}'}"
                                    TextColor="Gray" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button
                BackgroundColor="#E0E0E0"
                Clicked="OnCloseClicked"
                Grid.Row="4"
                Text="Закрыть"
                TextColor="Black" />
        </Grid>
    </Border>
</toolkit:Popup>
