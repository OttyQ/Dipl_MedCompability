<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    BackgroundColor="{StaticResource AppBackground}"
    Shell.NavBarIsVisible="False"
    x:Class="MedCompatibility.Pages.Doctor.DoctorCrossAnalysisPage"
    x:DataType="viewModels:DoctorCrossAnalysisViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:controls="clr-namespace:MedCompatibility.Pages.Shared.Controls"
    xmlns:models="clr-namespace:MedCompatibility.Models"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:viewModels="clr-namespace:MedCompatibility.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ContentPage.Resources>
        <ResourceDictionary>
            <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />

            <Style TargetType="Border" x:Key="InteractionTypeBadgeStyle">
                <Setter Property="StrokeThickness" Value="1.5" />
                <Setter Property="Padding" Value="10,4" />
                <Setter Property="StrokeShape" Value="RoundRectangle 8" />
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="Stroke" Value="{StaticResource Primary}" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>

            <Style TargetType="Border" x:Key="RiskBadgeBorderStyle">
                <Setter Property="Margin" Value="0,0,8,8" />
                <Setter Property="Padding" Value="10,4" />
                <Setter Property="StrokeShape" Value="RoundRectangle 8" />
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="BackgroundColor" Value="#EEEEEE" />
                <Style.Triggers>
                    <DataTrigger
                        Binding="{Binding Interaction.RiskLevel.Name}"
                        TargetType="Border"
                        Value="low">
                        <Setter Property="BackgroundColor" Value="#E3F2FD" />
                    </DataTrigger>
                    <DataTrigger
                        Binding="{Binding Interaction.RiskLevel.Name}"
                        TargetType="Border"
                        Value="medium">
                        <Setter Property="BackgroundColor" Value="#FFF3E0" />
                    </DataTrigger>
                    <DataTrigger
                        Binding="{Binding Interaction.RiskLevel.Name}"
                        TargetType="Border"
                        Value="high">
                        <Setter Property="BackgroundColor" Value="#FFEBEE" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="Label" x:Key="RiskLevelLabelStyle">
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="TextColor" Value="#424242" />
                <Style.Triggers>
                    <DataTrigger
                        Binding="{Binding Interaction.RiskLevel.Name}"
                        TargetType="Label"
                        Value="low">
                        <Setter Property="TextColor" Value="#1565C0" />
                        <Setter Property="Text" Value="Низкий риск" />
                    </DataTrigger>
                    <DataTrigger
                        Binding="{Binding Interaction.RiskLevel.Name}"
                        TargetType="Label"
                        Value="medium">
                        <Setter Property="TextColor" Value="#EF6C00" />
                        <Setter Property="Text" Value="Средний риск" />
                    </DataTrigger>
                    <DataTrigger
                        Binding="{Binding Interaction.RiskLevel.Name}"
                        TargetType="Label"
                        Value="high">
                        <Setter Property="TextColor" Value="#C62828" />
                        <Setter Property="Text" Value="Высокий риск" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <controls:BackgroundBubblesView />

        <Grid
            HorizontalOptions="Center"
            MaximumWidthRequest="800"
            RowDefinitions="Auto, *, Auto"
            Style="{StaticResource PageContentGrid}">

            <controls:CustomHeader
                Grid.Row="0"
                Margin="20,20,20,10"
                Title="Перекрестный анализ" />

            <ScrollView
                Grid.Row="1"
                Padding="20,0"
                VerticalScrollBarVisibility="Never">
                <VerticalStackLayout Spacing="16">

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Slots}" Spacing="12">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:MedicineSlot">
                                <Border
                                    BackgroundColor="{StaticResource Surface}"
                                    Padding="16"
                                    StrokeShape="RoundRectangle 16"
                                    StrokeThickness="0">
                                    <Border.Shadow>
                                        <Shadow
                                            Brush="Black"
                                            Offset="0,4"
                                            Opacity="0.05"
                                            Radius="8" />
                                    </Border.Shadow>
                                    <Grid ColumnDefinitions="*, Auto" ColumnSpacing="12">
                                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                            <VerticalStackLayout.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:DoctorCrossAnalysisViewModel}}, Path=SelectMedicineForSlotCommand}" CommandParameter="{Binding .}" />
                                            </VerticalStackLayout.GestureRecognizers>
                                            <Label
                                                FontAttributes="Italic"
                                                FontSize="15"
                                                IsVisible="{Binding IsPlaceholderVisible}"
                                                Text="{Binding DisplayName}"
                                                TextColor="{StaticResource TextSecondary}" />
                                            <VerticalStackLayout IsVisible="{Binding HasMedicine}" Spacing="2">
                                                <Label
                                                    FontAttributes="Bold"
                                                    FontSize="16"
                                                    LineBreakMode="WordWrap"
                                                    Text="{Binding DisplayName}"
                                                    TextColor="{StaticResource TextPrimary}" />
                                                <Label
                                                    FontSize="12"
                                                    Text="{Binding SelectedMedicine.ATCCode, StringFormat='АТХ: {0}'}"
                                                    TextColor="{StaticResource TextSecondary}">
                                                    <Label.Triggers>
                                                        <DataTrigger
                                                            Binding="{Binding SelectedMedicine.ATCCode}"
                                                            TargetType="Label"
                                                            Value="{x:Null}">
                                                            <Setter Property="IsVisible" Value="False" />
                                                        </DataTrigger>
                                                        <DataTrigger
                                                            Binding="{Binding SelectedMedicine.ATCCode}"
                                                            TargetType="Label"
                                                            Value="">
                                                            <Setter Property="IsVisible" Value="False" />
                                                        </DataTrigger>
                                                    </Label.Triggers>
                                                </Label>
                                                <Label
                                                    FontAttributes="Bold"
                                                    FontSize="12"
                                                    Text="{Binding InnMunText}"
                                                    TextColor="{StaticResource Primary}" />
                                            </VerticalStackLayout>
                                        </VerticalStackLayout>
                                        <HorizontalStackLayout
                                            Grid.Column="1"
                                            Spacing="8"
                                            VerticalOptions="Center">
                                            <Border
                                                BackgroundColor="#E3F2FD"
                                                HeightRequest="40"
                                                IsVisible="{Binding HasMedicine}"
                                                StrokeShape="RoundRectangle 10"
                                                WidthRequest="40">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:DoctorCrossAnalysisViewModel}}, Path=FindAlternativeCommand}" CommandParameter="{Binding SelectedMedicine}" />
                                                </Border.GestureRecognizers>
                                                <Label
                                                    FontSize="16"
                                                    HorizontalOptions="Center"
                                                    Text="🔄"
                                                    TextColor="{StaticResource Primary}"
                                                    VerticalOptions="Center" />
                                            </Border>
                                            <Border
                                                BackgroundColor="#FFEBEE"
                                                HeightRequest="40"
                                                StrokeShape="RoundRectangle 10"
                                                WidthRequest="40">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:DoctorCrossAnalysisViewModel}}, Path=RemoveSlotCommand}" CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                                <Label
                                                    FontSize="16"
                                                    HorizontalOptions="Center"
                                                    Text="🗑"
                                                    TextColor="#E53935"
                                                    VerticalOptions="Center" />
                                            </Border>
                                        </HorizontalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <!--  Панель подбора аналогов  -->
                    <VerticalStackLayout
                        IsVisible="{Binding IsAlternativesPanelVisible}"
                        Margin="0,10,0,0"
                        Spacing="10">
                        <Border
                            BackgroundColor="{StaticResource Surface}"
                            Padding="16"
                            StrokeShape="RoundRectangle 16"
                            StrokeThickness="0">
                            <Border.Shadow>
                                <Shadow
                                    Brush="Black"
                                    Offset="0,4"
                                    Opacity="0.05"
                                    Radius="8" />
                            </Border.Shadow>

                            <VerticalStackLayout Spacing="8">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="16"
                                    Text="{Binding TargetAlternativeDrug.TradeName, StringFormat='Замена для: {0}'}"
                                    TextColor="{StaticResource TextPrimary}" />

                                <Grid
                                    ColumnDefinitions="Auto, *"
                                    ColumnSpacing="5"
                                    Margin="0,10"
                                    RowDefinitions="Auto, Auto"
                                    RowSpacing="5">
                                    <CheckBox
                                        Color="{StaticResource Primary}"
                                        Grid.Column="0"
                                        Grid.Row="0"
                                        IsChecked="{Binding SearchOnlyBelarusian}"
                                        VerticalOptions="Center" />
                                    <Label
                                        FontSize="12"
                                        Grid.Column="1"
                                        Grid.Row="0"
                                        Text="Только производство РБ"
                                        TextColor="{StaticResource TextPrimary}"
                                        VerticalOptions="Center" />

                                    <CheckBox
                                        Color="{StaticResource Primary}"
                                        Grid.Column="0"
                                        Grid.Row="1"
                                        IsChecked="{Binding SearchByATC}"
                                        VerticalOptions="Center" />
                                    <Label
                                        FontSize="12"
                                        Grid.Column="1"
                                        Grid.Row="1"
                                        Text="Искать терапевтические аналоги (АТХ)"
                                        TextColor="{StaticResource TextPrimary}"
                                        VerticalOptions="Center" />
                                </Grid>

                                <Button
                                    Command="{Binding FindAlternativeCommand}"
                                    CommandParameter="{Binding TargetAlternativeDrug}"
                                    HeightRequest="40"
                                    Padding="0"
                                    Style="{StaticResource PrimaryButton}"
                                    Text="Найти" />

                                <ActivityIndicator
                                    Color="{StaticResource Primary}"
                                    HorizontalOptions="Center"
                                    IsRunning="{Binding IsSearchLoading}"
                                    IsVisible="{Binding IsSearchLoading}"
                                    Margin="0,10,0,0" />

                                <CollectionView
                                    IsVisible="{Binding HasAlternatives}"
                                    ItemsSource="{Binding SafeAlternatives}"
                                    Margin="0,10,0,0"
                                    MaximumHeightRequest="250">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="models:medicine">
                                            <Border
                                                BackgroundColor="#FAFAFA"
                                                Margin="0,0,0,8"
                                                Padding="12"
                                                Stroke="#E0E0E0"
                                                StrokeShape="RoundRectangle 8">
                                                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                                                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                                                        <Label
                                                            FontAttributes="Bold"
                                                            FontSize="14"
                                                            Text="{Binding TradeName}"
                                                            TextColor="{StaticResource TextPrimary}" />
                                                        <Label
                                                            FontSize="12"
                                                            Text="{Binding INN}"
                                                            TextColor="{StaticResource TextSecondary}" />
                                                        <HorizontalStackLayout Spacing="8">
                                                            <Border
                                                                BackgroundColor="#E3F2FD"
                                                                IsVisible="{Binding ATCCode, Converter={StaticResource StringNotNullOrEmptyConverter}}"
                                                                Padding="4,2"
                                                                StrokeShape="RoundRectangle 4"
                                                                StrokeThickness="0">
                                                                <Label
                                                                    FontAttributes="Bold"
                                                                    FontSize="11"
                                                                    Text="{Binding ATCCode}"
                                                                    TextColor="{StaticResource Primary}" />
                                                            </Border>
                                                            <Label
                                                                FontSize="11"
                                                                Text="{Binding Manufacturer.Name}"
                                                                TextColor="{StaticResource TextSecondary}"
                                                                VerticalOptions="Center" />
                                                        </HorizontalStackLayout>
                                                    </VerticalStackLayout>

                                                    <Button
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:DoctorCrossAnalysisViewModel}}, Path=ReplaceDrugCommand}"
                                                        CommandParameter="{Binding .}"
                                                        Grid.Column="1"
                                                        HeightRequest="36"
                                                        Padding="12,0"
                                                        Style="{StaticResource PrimaryButton}"
                                                        Text="Заменить"
                                                        VerticalOptions="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout
                        IsVisible="{Binding IsAnalysisDone}"
                        Margin="0,10,0,0"
                        Spacing="16">
                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            Text="Клинический отчет"
                            TextColor="{StaticResource TextPrimary}" />

                        <Border
                            BackgroundColor="{StaticResource Surface}"
                            Padding="20"
                            StrokeShape="RoundRectangle 20"
                            StrokeThickness="0">
                            <VerticalStackLayout Spacing="20">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="16"
                                    HorizontalOptions="Center"
                                    Text="Сводный клинический отчет"
                                    TextColor="{StaticResource Primary}" />
                                <BoxView
                                    Color="{StaticResource Primary}"
                                    HeightRequest="1"
                                    Opacity="0.1" />

                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding AnalysisReport}" Spacing="24">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="viewModels:CrossInteractionReport">
                                            <VerticalStackLayout Spacing="12">
                                                <Grid ColumnDefinitions="*, Auto, *" ColumnSpacing="10">
                                                    <VerticalStackLayout Grid.Column="0">
                                                        <Label
                                                            FontAttributes="Bold"
                                                            FontSize="13"
                                                            HorizontalTextAlignment="Center"
                                                            LineBreakMode="WordWrap"
                                                            Text="{Binding Medicine1.TradeName}"
                                                            TextColor="{StaticResource TextPrimary}" />
                                                        <Label
                                                            FontSize="11"
                                                            HorizontalTextAlignment="Center"
                                                            Text="{Binding Medicine1.ATCCode, StringFormat='АТХ: {0}'}"
                                                            TextColor="{StaticResource TextSecondary}">
                                                            <Label.Triggers>
                                                                <DataTrigger
                                                                    Binding="{Binding Medicine1.ATCCode}"
                                                                    TargetType="Label"
                                                                    Value="{x:Null}">
                                                                    <Setter Property="IsVisible" Value="False" />
                                                                </DataTrigger>
                                                                <DataTrigger
                                                                    Binding="{Binding Medicine1.ATCCode}"
                                                                    TargetType="Label"
                                                                    Value="">
                                                                    <Setter Property="IsVisible" Value="False" />
                                                                </DataTrigger>
                                                            </Label.Triggers>
                                                        </Label>
                                                        <Label
                                                            FontAttributes="Italic"
                                                            FontSize="10"
                                                            HorizontalTextAlignment="Center"
                                                            Text="{Binding Med1Substances}"
                                                            TextColor="{StaticResource TextSecondary}" />
                                                    </VerticalStackLayout>

                                                    <Label
                                                        FontSize="20"
                                                        Grid.Column="1"
                                                        HorizontalOptions="Center"
                                                        IsVisible="{Binding IsConflict}"
                                                        Text="⚡"
                                                        TextColor="#E53935" />
                                                    <Label
                                                        FontSize="20"
                                                        Grid.Column="1"
                                                        HorizontalOptions="Center"
                                                        IsVisible="{Binding IsConflict, Converter={StaticResource InvertedBoolConverter}}"
                                                        Text="✅"
                                                        TextColor="#389E0D" />

                                                    <VerticalStackLayout Grid.Column="2">
                                                        <Label
                                                            FontAttributes="Bold"
                                                            FontSize="13"
                                                            HorizontalTextAlignment="Center"
                                                            LineBreakMode="WordWrap"
                                                            Text="{Binding Medicine2.TradeName}"
                                                            TextColor="{StaticResource TextPrimary}" />
                                                        <Label
                                                            FontSize="11"
                                                            HorizontalTextAlignment="Center"
                                                            Text="{Binding Medicine2.ATCCode, StringFormat='АТХ: {0}'}"
                                                            TextColor="{StaticResource TextSecondary}">
                                                            <Label.Triggers>
                                                                <DataTrigger
                                                                    Binding="{Binding Medicine2.ATCCode}"
                                                                    TargetType="Label"
                                                                    Value="{x:Null}">
                                                                    <Setter Property="IsVisible" Value="False" />
                                                                </DataTrigger>
                                                                <DataTrigger
                                                                    Binding="{Binding Medicine2.ATCCode}"
                                                                    TargetType="Label"
                                                                    Value="">
                                                                    <Setter Property="IsVisible" Value="False" />
                                                                </DataTrigger>
                                                            </Label.Triggers>
                                                        </Label>
                                                        <Label
                                                            FontAttributes="Italic"
                                                            FontSize="10"
                                                            HorizontalTextAlignment="Center"
                                                            Text="{Binding Med2Substances}"
                                                            TextColor="{StaticResource TextSecondary}" />
                                                    </VerticalStackLayout>
                                                </Grid>

                                                <VerticalStackLayout IsVisible="{Binding IsConflict}" Spacing="10">
                                                    <FlexLayout Direction="Row" Wrap="Wrap">
                                                        <Border Style="{StaticResource RiskBadgeBorderStyle}">
                                                            <Label Style="{StaticResource RiskLevelLabelStyle}" />
                                                        </Border>

                                                        <Border Margin="0,0,0,8" Style="{StaticResource InteractionTypeBadgeStyle}">
                                                            <Label
                                                                FontAttributes="Bold"
                                                                FontSize="11"
                                                                Text="{Binding Interaction.InteractionType.Name}"
                                                                TextColor="{StaticResource Primary}" />
                                                        </Border>
                                                    </FlexLayout>

                                                    <Label
                                                        FontSize="13"
                                                        LineBreakMode="WordWrap"
                                                        Text="{Binding Interaction.Description}"
                                                        TextColor="{StaticResource TextPrimary}" />

                                                    <Border
                                                        BackgroundColor="#F0F7F7"
                                                        Padding="12"
                                                        StrokeShape="RoundRectangle 10">
                                                        <Label
                                                            FontAttributes="Italic"
                                                            FontSize="13"
                                                            LineBreakMode="WordWrap"
                                                            Text="{Binding Interaction.Recommendation}"
                                                            TextColor="{StaticResource Primary}" />
                                                    </Border>
                                                </VerticalStackLayout>

                                                <Border
                                                    BackgroundColor="#F6FFED"
                                                    IsVisible="{Binding IsConflict, Converter={StaticResource InvertedBoolConverter}}"
                                                    Padding="15"
                                                    Stroke="#B7EB8F"
                                                    StrokeShape="RoundRectangle 12">
                                                    <Label
                                                        FontAttributes="Bold"
                                                        FontSize="13"
                                                        HorizontalOptions="Center"
                                                        Text="{Binding SuccessMessage}"
                                                        TextColor="#389E0D" />
                                                </Border>

                                                <BoxView
                                                    Color="{StaticResource TextSecondary}"
                                                    HeightRequest="1"
                                                    Margin="0,15,0,0"
                                                    Opacity="0.1" />
                                            </VerticalStackLayout>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>

                                <HorizontalStackLayout
                                    HorizontalOptions="Center"
                                    Margin="0,10,0,0"
                                    Spacing="10">
                                    <Button
                                        BackgroundColor="White"
                                        BorderColor="{StaticResource Primary}"
                                        BorderWidth="1.5"
                                        Command="{Binding SaveReportCommand}"
                                        CornerRadius="10"
                                        FontAttributes="Bold"
                                        Padding="20,10"
                                        Text="Скачать PDF"
                                        TextColor="{StaticResource Primary}" />
                                    <Button
                                        BackgroundColor="White"
                                        BorderColor="{StaticResource Primary}"
                                        BorderWidth="1.5"
                                        Command="{Binding ShareReportCommand}"
                                        CornerRadius="10"
                                        FontAttributes="Bold"
                                        Padding="20,10"
                                        Text="Поделиться"
                                        TextColor="{StaticResource Primary}" />
                                </HorizontalStackLayout>

                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>

                    <!--  ИИ-АНАЛИЗ: спиннер + карточка результата (без кнопки, она внизу)  -->
                    <VerticalStackLayout
                        IsVisible="{Binding IsAnalysisDone}"
                        Margin="0,4,0,0"
                        Spacing="12">

                        <!--  Спиннер загрузки  -->
                        <ActivityIndicator
                            Color="{StaticResource Primary}"
                            HorizontalOptions="Center"
                            IsRunning="{Binding IsAiLoading}"
                            IsVisible="{Binding IsAiLoading}"
                            Margin="0,4,0,0" />

                        <!--  Карточка результата ИИ  -->
                        <Border
                            BackgroundColor="{StaticResource Surface}"
                            IsVisible="{Binding AiAnalysisVisible}"
                            Padding="0"
                            StrokeShape="RoundRectangle 20"
                            StrokeThickness="0">
                            <Border.Shadow>
                                <Shadow
                                    Brush="Black"
                                    Offset="0,4"
                                    Opacity="0.06"
                                    Radius="8" />
                            </Border.Shadow>

                            <Grid ColumnDefinitions="6, *">
                                <!--  Левая цветная полоса  -->
                                <BoxView
                                    BackgroundColor="{StaticResource Primary}"
                                    CornerRadius="20,0,0,20"
                                    Grid.Column="0" />

                                <VerticalStackLayout
                                    Grid.Column="1"
                                    Padding="16,16,16,16"
                                    Spacing="8">

                                    <!--  Заголовок  -->
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="16"
                                        Text="🤖 ИИ анализ"
                                        TextColor="{StaticResource Primary}" />

                                    <!--  Дисклеймер  -->
                                    <Label
                                        FontAttributes="Italic"
                                        FontSize="11"
                                        Text="Результат не заменяет клиническое суждение врача"
                                        TextColor="{StaticResource TextSecondary}" />

                                    <BoxView
                                        Color="{StaticResource TextSecondary}"
                                        HeightRequest="1"
                                        Opacity="0.1" />

                                    <!--  Текст ответа  -->
                                    <Label
                                        FontSize="14"
                                        LineBreakMode="WordWrap"
                                        Text="{Binding AiAnalysisResult}"
                                        TextColor="{StaticResource TextPrimary}" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </ScrollView>

            <VerticalStackLayout
                Grid.Row="2"
                Padding="20,10,20,20"
                Spacing="10">
                <Button
                    BackgroundColor="#E0F2F1"
                    Command="{Binding AddSlotCommand}"
                    CornerRadius="12"
                    FontAttributes="Bold"
                    HeightRequest="52"
                    Text="+ Добавить препарат"
                    TextColor="#00695C" />
                <Button
                    Command="{Binding AnalyzeCommand}"
                    CornerRadius="12"
                    FontAttributes="Bold"
                    HeightRequest="52"
                    Style="{StaticResource PrimaryButton}"
                    Text="Проверить совместимость" />
                <!--  Кнопка ИИ анализа закреплена внизу, видна только после анализа  -->
                <Button
                    Command="{Binding RunAiAnalysisCommand}"
                    CornerRadius="12"
                    FontAttributes="Bold"
                    HeightRequest="52"
                    IsVisible="{Binding IsAnalysisDone}"
                    Style="{StaticResource PrimaryButton}"
                    Text="🤖  ИИ анализ" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>