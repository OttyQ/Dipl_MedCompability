<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    BackgroundColor="{StaticResource AppBackground}"
    Shell.NavBarIsVisible="False"
    Title="Мои пациенты"
    x:Class="MedCompatibility.Pages.Doctor.DoctorPatientsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:controls="clr-namespace:MedCompatibility.Pages.Shared.Controls"
    xmlns:converters="clr-namespace:MedCompatibility.Converters"
    xmlns:models="clr-namespace:MedCompatibility.Models"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:StringFirstCharConverter x:Key="StringFirstCharConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <!--  фон  -->
        <controls:BackgroundBubblesView />

        <Grid Style="{StaticResource PageContentGrid}" RowDefinitions="Auto,*">
                <!--  Шапка  -->
                <controls:CustomHeader
                    Margin="0,0,0,5"
                    Title="Мои пациенты" />

            <!--  Контент  -->
            <ScrollView Grid.Row="1" Padding="16,0">
                <VerticalStackLayout
                    HorizontalOptions="Fill"
                    MaximumWidthRequest="800"
                    Spacing="16">

                    <!--  Кнопка добавить  -->
                    <Button
                        Command="{Binding AddPatientCommand}"
                        CornerRadius="14"
                        FontAttributes="Bold"
                        FontSize="16"
                        HeightRequest="54"
                        Style="{StaticResource PrimaryButton}"
                        Text="+ Добавить пациента">
                        <Button.Shadow>
                            <Shadow
                                Brush="{StaticResource Primary}"
                                Offset="0,4"
                                Opacity="0.3"
                                Radius="8" />
                        </Button.Shadow>
                    </Button>

                    <BoxView Color="Transparent" HeightRequest="4" />

                    <!--  Список  -->
                    <CollectionView
                        EmptyView="Нет пациентов"
                        HorizontalOptions="Fill"
                        ItemsSource="{Binding Patients}"
                        SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout ItemSpacing="15" Orientation="Vertical" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:user">
                                <Border
                                    BackgroundColor="{StaticResource Surface}"
                                    Margin="0,0,0,12"
                                    Padding="16"
                                    StrokeShape="RoundRectangle 16"
                                    StrokeThickness="0">
                                    <Border.Shadow>
                                        <Shadow
                                            Brush="Black"
                                            Offset="0,4"
                                            Opacity="0.05"
                                            Radius="8" />
                                    </Border.Shadow>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenPatientCommand}" CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>

                                    <Grid ColumnDefinitions="50,*,Auto" ColumnSpacing="16">
                                        <!--  Аватарка с первой буквой  -->
                                        <Border
                                            BackgroundColor="#E0F2F1"
                                            HeightRequest="50"
                                            StrokeShape="RoundRectangle 25"
                                            StrokeThickness="0"
                                            WidthRequest="50">
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="20"
                                                HorizontalOptions="Center"
                                                Text="{Binding LastName, Converter={StaticResource StringFirstCharConverter}}"
                                                TextColor="{StaticResource Primary}"
                                                VerticalOptions="Center" />
                                        </Border>

                                        <!--  Инфо  -->
                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="16"
                                                LineBreakMode="TailTruncation"
                                                Text="{Binding LastName}"
                                                TextColor="{StaticResource TextPrimary}">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="{Binding LastName}" />
                                                        <Span Text=" " />
                                                        <Span Text="{Binding FirstName}" />
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                            <Label
                                                FontSize="13"
                                                LineBreakMode="TailTruncation"
                                                Text="{Binding Login}"
                                                TextColor="{StaticResource TextSecondary}" />
                                        </VerticalStackLayout>

                                        <!--  Стрелка  -->
                                        <Label
                                            FontSize="20"
                                            Grid.Column="2"
                                            Text="›"
                                            TextColor="{StaticResource TextSecondary}"
                                            VerticalOptions="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <BoxView HeightRequest="20" />
                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Grid>
</ContentPage>
