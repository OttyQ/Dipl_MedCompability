<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    BackgroundColor="{StaticResource AppBackground}"
    Shell.NavBarIsVisible="False"
    Title="Мои пациенты"
    x:Class="MedCompatibility.Pages.Doctor.DoctorPatientsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:controls="clr-namespace:MedCompatibility.Pages.Shared.Controls"
    xmlns:converters="clr-namespace:MedCompatibility.Converters"
    xmlns:models="clr-namespace:MedCompatibility.Models"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:StringFirstCharConverter x:Key="StringFirstCharConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <!--  фон  -->
        <controls:BackgroundBubblesView />

        <Grid RowDefinitions="Auto,Auto,*" Style="{StaticResource PageContentGrid}" WidthRequest="{OnPlatform WinUI=800, MacCatalyst=800}">
            <!--  Шапка  -->
            <controls:CustomHeader
                Grid.Row="0"
                Margin="20,20,20,10"
                Title="Мои пациенты" />

            <!--  Контент  -->
            <ScrollView Grid.Row="1" Padding="20,0">
                <VerticalStackLayout HorizontalOptions="Fill" Spacing="16">

                    <!--  Кнопка добавить  -->
                    <Button
                        Command="{Binding AddPatientCommand}"
                        CornerRadius="14"
                        FontAttributes="Bold"
                        FontSize="16"
                        HeightRequest="54"
                        Style="{StaticResource PrimaryButton}"
                        Text="+ Добавить пациента">
                        <Button.Shadow>
                            <Shadow
                                Brush="{StaticResource Primary}"
                                Offset="0,4"
                                Opacity="0.3"
                                Radius="8" />
                        </Button.Shadow>
                    </Button>

                    <BoxView Color="Transparent" HeightRequest="4" />

                    <!--  Заглушка "Нет данных" (для Android)  -->
                    <VerticalStackLayout
                        HorizontalOptions="Center"
                        IsVisible="{Binding IsEmpty}"
                        Padding="0,50"
                        Spacing="10"
                        VerticalOptions="Center">
                        <Label
                            FontSize="40"
                            HorizontalOptions="Center"
                            Opacity="0.5"
                            Text="👥" />
                        <Label
                            FontSize="16"
                            HorizontalOptions="Center"
                            Text="Нет пациентов"
                            TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>

                    <!--  Список  -->
                    <CollectionView
                        HorizontalOptions="Fill"
                        ItemsSource="{Binding Patients}"
                        SelectionMode="None">
                        <CollectionView.Triggers>
                            <DataTrigger
                                Binding="{Binding IsEmpty}"
                                TargetType="CollectionView"
                                Value="True">
                                <Setter Property="IsVisible" Value="False" />
                            </DataTrigger>
                        </CollectionView.Triggers>
                        <CollectionView.ItemsLayout>


                            <LinearItemsLayout ItemSpacing="15" Orientation="Vertical" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:user">
                                <Border
                                    BackgroundColor="{StaticResource Surface}"
                                    Margin="0,0,0,12"
                                    Padding="16"
                                    StrokeShape="RoundRectangle 16"
                                    StrokeThickness="0">
                                    <Border.Shadow>
                                        <Shadow
                                            Brush="Black"
                                            Offset="0,4"
                                            Opacity="0.05"
                                            Radius="8" />
                                    </Border.Shadow>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenPatientCommand}" CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>

                                    <Grid ColumnDefinitions="50,*,Auto" ColumnSpacing="16">
                                        <!--  Аватарка с первой буквой  -->
                                        <Border
                                            BackgroundColor="#E0F2F1"
                                            HeightRequest="50"
                                            StrokeShape="RoundRectangle 25"
                                            StrokeThickness="0"
                                            WidthRequest="50">
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="20"
                                                HorizontalOptions="Center"
                                                Text="{Binding LastName, Converter={StaticResource StringFirstCharConverter}}"
                                                TextColor="{StaticResource Primary}"
                                                VerticalOptions="Center" />
                                        </Border>

                                        <!--  Инфо  -->
                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="16"
                                                LineBreakMode="TailTruncation"
                                                Text="{Binding LastName}"
                                                TextColor="{StaticResource TextPrimary}">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="{Binding LastName}" />
                                                        <Span Text=" " />
                                                        <Span Text="{Binding FirstName}" />
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                            <Label
                                                FontSize="13"
                                                LineBreakMode="TailTruncation"
                                                Text="{Binding Login}"
                                                TextColor="{StaticResource TextSecondary}" />
                                        </VerticalStackLayout>

                                        <!--  Кнопка удаления + Стрелка  -->
                                        <HorizontalStackLayout Grid.Column="2" Spacing="8" VerticalOptions="Center">
                                            <Border
                                                BackgroundColor="#FFEBEE"
                                                HeightRequest="36"
                                                StrokeShape="RoundRectangle 10"
                                                StrokeThickness="0"
                                                WidthRequest="36">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeletePatientCommand}" CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                                <Label
                                                    FontSize="16"
                                                    HorizontalOptions="Center"
                                                    Text="🗑"
                                                    TextColor="#E53935"
                                                    VerticalOptions="Center" />
                                            </Border>
                                            <Label
                                                FontSize="20"
                                                Text="›"
                                                TextColor="{StaticResource TextSecondary}"
                                                VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <BoxView HeightRequest="20" />
                </VerticalStackLayout>
            </ScrollView>
        </Grid>

    </Grid>
</ContentPage>
