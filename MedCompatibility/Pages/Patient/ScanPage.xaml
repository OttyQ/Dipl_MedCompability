<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    BackgroundColor="{StaticResource AppBackground}"
    Shell.NavBarIsVisible="False"
    Title="Проверка лекарств"
    x:Class="MedCompatibility.Pages.Patient.ScanPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:controls="clr-namespace:MedCompatibility.Pages.Shared.Controls"
    xmlns:models="clr-namespace:MedCompatibility.Models"
    xmlns:vm="clr-namespace:MedCompatibility.ViewModels.Patient"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Grid>
        <!--  фон  -->
        <controls:BackgroundBubblesView />

        <Grid
            HorizontalOptions="{OnPlatform WinUI=Center,
                                           MacCatalyst=Center,
                                           Default=Fill}"
            Margin="{OnPlatform WinUI='0,20',
                                MacCatalyst='0,20',
                                Default='0'}"
            MaximumWidthRequest="700"
            RowDefinitions="Auto, *"
            WidthRequest="{OnPlatform WinUI=700,
                                      MacCatalyst=700}">

            <VerticalStackLayout
                Grid.Row="0"
                Padding="20"
                Spacing="20">

                <Label
                    FontAttributes="Bold"
                    FontSize="22"
                    HorizontalOptions="Center"
                    Text="Поиск и сканирование"
                    TextColor="{StaticResource Primary}" />

                <Grid
                    ColumnDefinitions="*, 130"
                    ColumnSpacing="15"
                    HeightRequest="50">

                    <Border
                        BackgroundColor="White"
                        Grid.Column="0"
                        HorizontalOptions="Fill"
                        Padding="15,0,5,0"
                        StrokeShape="RoundRectangle 25"
                        StrokeThickness="0"
                        VerticalOptions="Fill">
                        <Border.Shadow>
                            <Shadow
                                Brush="Black"
                                Offset="0,4"
                                Opacity="0.1"
                                Radius="10" />
                        </Border.Shadow>

                        <Grid ColumnDefinitions="*, Auto">
                            <Entry
                                Grid.Column="0"
                                Placeholder="Введите название или штрихкод..."
                                ReturnCommand="{Binding SearchCommand}"
                                Text="{Binding SearchQuery}"
                                TextColor="{StaticResource TextPrimary}"
                                VerticalOptions="Center" />

                            <Button
                                BackgroundColor="Transparent"
                                Command="{Binding ClearSearchCommand}"
                                FontSize="18"
                                Grid.Column="1"
                                HeightRequest="40"
                                IsVisible="{Binding IsClearButtonVisible}"
                                Padding="0"
                                Text="✕"
                                TextColor="#999"
                                VerticalOptions="Center"
                                WidthRequest="40" />
                        </Grid>
                    </Border>

                    <Button
                        BackgroundColor="{StaticResource Primary}"
                        Command="{Binding SearchCommand}"
                        CornerRadius="25"
                        FontAttributes="Bold"
                        Grid.Column="1"
                        HorizontalOptions="Fill"
                        Text="Поиск"
                        TextColor="White"
                        VerticalOptions="Fill">
                        <Button.Shadow>
                            <Shadow
                                Brush="{StaticResource Primary}"
                                Offset="0,4"
                                Opacity="0.3"
                                Radius="10" />
                        </Button.Shadow>
                    </Button>
                </Grid>

                <Button
                    BackgroundColor="{StaticResource Secondary}"
                    Command="{Binding ScanBarcodeCommand}"
                    CornerRadius="25"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    Text="📷 Сканировать код"
                    TextColor="White">
                    <Button.IsVisible>
                        <OnPlatform x:TypeArguments="x:Boolean">
                            <On Platform="Android,iOS" Value="True" />
                            <On Platform="WinUI,MacCatalyst" Value="False" />
                        </OnPlatform>
                    </Button.IsVisible>
                </Button>

            </VerticalStackLayout>

            <Grid Grid.Row="1" Padding="20,0,20,20">

                <ActivityIndicator
                    Color="{StaticResource Primary}"
                    HorizontalOptions="Center"
                    IsRunning="{Binding IsBusy}"
                    IsVisible="{Binding IsBusy}"
                    Margin="0,30,0,0"
                    VerticalOptions="Start" />

                <Label
                    HorizontalOptions="Center"
                    IsVisible="{Binding IsNotFoundVisible}"
                    Margin="0,30,0,0"
                    Text="Лекарства не найдены в базе."
                    TextColor="#FF5252"
                    VerticalOptions="Start" />

                <CollectionView
                    IsVisible="{Binding IsMedicineVisible}"
                    ItemsSource="{Binding FoundMedicines}"
                    SelectionMode="None">

                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout ItemSpacing="15" Orientation="Vertical" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:medicine">
                            <Border
                                BackgroundColor="White"
                                Padding="15"
                                StrokeShape="RoundRectangle 15"
                                StrokeThickness="0">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ScanPageViewModel}}, Path=GoToDetailsCommand}" CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Border.Shadow>
                                    <Shadow
                                        Brush="Black"
                                        Offset="0,2"
                                        Opacity="0.05"
                                        Radius="5" />
                                </Border.Shadow>
                                <Grid ColumnDefinitions="*, Auto">
                                    <VerticalStackLayout Spacing="5">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="18"
                                            Text="{Binding TradeName}"
                                            TextColor="{StaticResource TextPrimary}" />
                                        <Label
                                            FontSize="13"
                                            Text="{Binding INN}"
                                            TextColor="{StaticResource TextSecondary}" />
                                        <Label
                                            FontSize="11"
                                            Text="{Binding GTIN, StringFormat='GTIN: {0}'}"
                                            TextColor="#999" />
                                    </VerticalStackLayout>
                                    <Label
                                        FontSize="24"
                                        Grid.Column="1"
                                        Text="›"
                                        TextColor="{StaticResource Primary}"
                                        VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>