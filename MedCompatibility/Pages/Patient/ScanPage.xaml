<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    BackgroundColor="{StaticResource AppBackground}"
    Title="Проверка лекарств"
    x:Class="MedCompatibility.Pages.Patient.ScanPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:vm="clr-namespace:MedCompatibility.ViewModels.Patient"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!--  Заголовок  -->
            <Label
                FontAttributes="Bold"
                FontSize="22"
                HorizontalOptions="Center"
                Text="Проверка совместимости"
                TextColor="{StaticResource Primary}" />

            <!--  Поле поиска  -->
            <Border
                BackgroundColor="White"
                HeightRequest="50"
                Padding="15,0"
                StrokeShape="RoundRectangle 25"
                StrokeThickness="0">
                <Border.Shadow>
                    <Shadow
                        Brush="Black"
                        Offset="0,4"
                        Opacity="0.1"
                        Radius="10" />
                </Border.Shadow>
                <Grid ColumnDefinitions="*, Auto">
                    <Entry
                        Placeholder="Введите название или штрихкод"
                        ReturnCommand="{Binding SearchCommand}"
                        Text="{Binding SearchQuery}"
                        TextColor="{StaticResource TextPrimary}"
                        VerticalOptions="Center" />

                    <ImageButton
                        Command="{Binding SearchCommand}"
                        Grid.Column="1"
                        HeightRequest="24"
                        Source="search_icon.png"
                        VerticalOptions="Center"
                        WidthRequest="24">
                        <!--  Если нет иконки, можно текст  -->
                    </ImageButton>
                </Grid>
            </Border>

            <!--  Кнопка сканера  -->
            <Button
                BackgroundColor="{StaticResource Primary}"
                Command="{Binding ScanBarcodeCommand}"
                CornerRadius="25"
                FontAttributes="Bold"
                HeightRequest="50"
                Text="📷 Сканировать штрихкод"
                TextColor="White" />

            <!--  Результат: Лекарство найдено  -->
            <Border
                BackgroundColor="White"
                IsVisible="{Binding IsMedicineVisible}"
                Padding="15"
                StrokeShape="RoundRectangle 15"
                StrokeThickness="0">
                <VerticalStackLayout Spacing="10">
                    <Label
                        FontSize="12"
                        Text="Результат:"
                        TextColor="#999" />
                    <Label
                        FontAttributes="Bold"
                        FontSize="20"
                        Text="{Binding FoundMedicine.TradeName}"
                        TextColor="{StaticResource TextPrimary}" />
                    <Label
                        FontSize="14"
                        Text="{Binding FoundMedicine.INN}"
                        TextColor="{StaticResource TextSecondary}" />

                    <BoxView
                        Color="#EEE"
                        HeightRequest="1"
                        Margin="0,5" />

                    <Label
                        FontAttributes="Bold"
                        Text="Состав:"
                        TextColor="{StaticResource TextPrimary}" />

                    <Label
                        FontSize="12"
                        Text="✅ Лекарство распознано и добавлено в историю."
                        TextColor="Green" />
                </VerticalStackLayout>
            </Border>

            <!--  Результат: Не найдено  -->
            <Label
                HorizontalOptions="Center"
                IsVisible="{Binding IsNotFoundVisible}"
                Text="Лекарство не найдено в базе данных."
                TextColor="#FF5252" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
