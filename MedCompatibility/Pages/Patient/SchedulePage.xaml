<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    BackgroundColor="{StaticResource AppBackground}"
    Shell.NavBarIsVisible="False"
    x:Class="MedCompatibility.Pages.Patient.SchedulePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:controls="clr-namespace:MedCompatibility.Pages.Shared.Controls"
    xmlns:models="clr-namespace:MedCompatibility.Models"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:vm="clr-namespace:MedCompatibility.ViewModels.Patient"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Grid>
        <controls:BackgroundBubblesView />

        <Grid
            HorizontalOptions="{OnPlatform WinUI=Center,
                                           Default=Fill}"
            MaximumWidthRequest="{OnPlatform WinUI=800,
                                             Default=9999}"
            RowDefinitions="Auto, Auto, *">

            <controls:CustomHeader
                Grid.Row="0"
                IsBackButtonVisible="True"
                Margin="{OnPlatform WinUI='0,40,0,20',
                                    Default='20,20,20,10'}"
                Title="Мои назначения" />

            <Border
                BackgroundColor="White"
                Grid.Row="1"
                HorizontalOptions="{OnPlatform WinUI=Center,
                                               Default=Fill}"
                Margin="{OnPlatform WinUI='0,0,0,20',
                                    Default='20,0,20,10'}"
                MaximumWidthRequest="{OnPlatform WinUI=600,
                                                 Default=9999}"
                Padding="16,16"
                StrokeShape="RoundRectangle 20"
                StrokeThickness="0">
                <Border.Shadow>
                    <Shadow
                        Brush="Black"
                        Offset="0,4"
                        Opacity="0.06"
                        Radius="10" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="15">

                    <Grid ColumnDefinitions="36,*,36">

                        <Button
                            BackgroundColor="Transparent"
                            Command="{Binding PreviousWeekCommand}"
                            FontSize="18"
                            Grid.Column="0"
                            HeightRequest="36"
                            Padding="0"
                            Text="←"
                            TextColor="{StaticResource TextPrimary}"
                            WidthRequest="36" />

                        <Grid Grid.Column="1" HorizontalOptions="Center">
                            <Label
                                FontAttributes="Bold"
                                FontSize="16"
                                HorizontalOptions="Center"
                                Text="{Binding MonthYearLabel}"
                                TextColor="{StaticResource TextPrimary}"
                                VerticalOptions="Center" />

                            <DatePicker
                                Date="{Binding SelectedDate}"
                                DateSelected="OnDatePickerSelected"
                                HorizontalOptions="Fill"
                                InputTransparent="False"
                                IsVisible="True"
                                Opacity="0.02"
                                VerticalOptions="Fill"
                                x:Name="WeekDatePicker" />
                        </Grid>

                        <Button
                            BackgroundColor="Transparent"
                            Command="{Binding NextWeekCommand}"
                            FontSize="18"
                            Grid.Column="2"
                            HeightRequest="36"
                            Padding="0"
                            Text="→"
                            TextColor="{StaticResource TextPrimary}"
                            WidthRequest="36" />

                    </Grid>

                    <CollectionView
                        HeightRequest="70"
                        HorizontalOptions="Center"
                        HorizontalScrollBarVisibility="Never"
                        ItemsSource="{Binding WeekDays}"
                        VerticalScrollBarVisibility="Never">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout ItemSpacing="{OnPlatform WinUI=16, Default=2}" Orientation="Horizontal" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:CalendarDayItem">
                                <Grid
                                    HeightRequest="68"
                                    HorizontalOptions="Center"
                                    Padding="2"
                                    WidthRequest="{OnPlatform WinUI=52,
                                                              Default=44}">
                                    <Border
                                        BackgroundColor="Transparent"
                                        Stroke="#BDBDBD"
                                        StrokeShape="RoundRectangle 10"
                                        StrokeThickness="0">
                                        <Border.Triggers>
                                            <!--  Выделение выбранного дня (серая обводка)  -->
                                            <DataTrigger
                                                Binding="{Binding IsSelected}"
                                                TargetType="Border"
                                                Value="True">
                                                <Setter Property="StrokeThickness" Value="1.5" />
                                            </DataTrigger>
                                            <!--  Подсветка сегодня (зеленый фон)  -->
                                            <DataTrigger
                                                Binding="{Binding Date, Converter={StaticResource IsEqualToTodayConverter}}"
                                                TargetType="Border"
                                                Value="True">
                                                <Setter Property="BackgroundColor" Value="#00796B" />
                                                <Setter Property="StrokeThickness" Value="0" />
                                            </DataTrigger>
                                        </Border.Triggers>
                                    </Border>

                                    <VerticalStackLayout
                                        HorizontalOptions="Center"
                                        Spacing="2"
                                        VerticalOptions="Center">

                                        <Label
                                            FontSize="11"
                                            HorizontalOptions="Center"
                                            TextColor="{StaticResource TextSecondary}">
                                            <Label.Text>
                                                <Binding Converter="{StaticResource DateToDayNameConverter}" Path="Date" />
                                            </Label.Text>
                                            <Label.Triggers>
                                                <DataTrigger
                                                    Binding="{Binding Date, Converter={StaticResource IsEqualToTodayConverter}}"
                                                    TargetType="Label"
                                                    Value="True">
                                                    <Setter Property="TextColor" Value="White" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>

                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="15"
                                            HorizontalOptions="Center"
                                            TextColor="{StaticResource TextPrimary}">
                                            <Label.Text>
                                                <Binding Path="Date" StringFormat="{}{0:%d}" />
                                            </Label.Text>
                                            <Label.Triggers>
                                                <DataTrigger
                                                    Binding="{Binding Date, Converter={StaticResource IsEqualToTodayConverter}}"
                                                    TargetType="Label"
                                                    Value="True">
                                                    <Setter Property="TextColor" Value="White" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>

                                        <Ellipse
                                            Fill="{Binding Type, Converter={StaticResource DayTypeToColorConverter}}"
                                            HeightRequest="5"
                                            HorizontalOptions="Center"
                                            WidthRequest="5" />

                                    </VerticalStackLayout>

                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ScheduleViewModel}}, Path=SelectDateCommand}" CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>

                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Border>

            <ScrollView 
                Grid.Row="2" 
                HorizontalOptions="{OnPlatform WinUI=Center, MacCatalyst=Center, Default=Fill}"
                MaximumWidthRequest="{OnPlatform WinUI=600, MacCatalyst=600, Default=9999}"
                WidthRequest="{OnPlatform WinUI=600, MacCatalyst=600}"
                VerticalScrollBarVisibility="Never">
                
                <VerticalStackLayout 
                    Padding="20,0,20,40" 
                    Spacing="16">

                    <Label
                        FontAttributes="Bold"
                        FontSize="16"
                        Margin="0,10,0,0"
                        Text="{Binding SelectedDateSummaryLabel}"
                        TextColor="{StaticResource TextPrimary}" />

                    <Label
                        HorizontalOptions="Fill"
                        HorizontalTextAlignment="Center"
                        IsVisible="{Binding IsEmpty}"
                        Margin="0,30"
                        Text="На этот день назначений нет"
                        TextColor="{StaticResource TextSecondary}" />

                    <CollectionView
                        IsVisible="{Binding IsEmpty, Converter={StaticResource InverseBoolConverter}}"
                        ItemsSource="{Binding PrescriptionsForDay}"
                        VerticalScrollBarVisibility="Never">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout ItemSpacing="12" Orientation="Vertical" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:prescription">
                                <Border
                                    Padding="16"
                                    StrokeShape="RoundRectangle 16"
                                    StrokeThickness="0">
                                    <Border.Shadow>
                                        <Shadow
                                            Brush="Black"
                                            Offset="0,2"
                                            Opacity="0.05"
                                            Radius="6" />
                                    </Border.Shadow>

                                    <Border.Triggers>
                                        <DataTrigger
                                            Binding="{Binding EndDate, Converter={StaticResource IsDateExpiredConverter}}"
                                            TargetType="Border"
                                            Value="False">
                                            <Setter Property="BackgroundColor" Value="White" />
                                        </DataTrigger>
                                        <DataTrigger
                                            Binding="{Binding EndDate, Converter={StaticResource IsDateExpiredConverter}}"
                                            TargetType="Border"
                                            Value="True">
                                            <Setter Property="BackgroundColor" Value="#FAFAFA" />
                                        </DataTrigger>
                                    </Border.Triggers>

                                    <VerticalStackLayout Spacing="8">
                                        <Grid ColumnDefinitions="Auto, *">
                                            <Border
                                                BackgroundColor="#E3F2FD"
                                                Grid.Column="0"
                                                HeightRequest="40"
                                                Margin="0,0,12,0"
                                                StrokeShape="RoundRectangle 8"
                                                StrokeThickness="0"
                                                WidthRequest="40">
                                                <Label
                                                    FontSize="18"
                                                    HorizontalOptions="Center"
                                                    Text="💊"
                                                    VerticalOptions="Center" />
                                            </Border>

                                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                                <Label
                                                    FontAttributes="Bold"
                                                    FontSize="16"
                                                    Text="{Binding Medicine.TradeName}"
                                                    TextColor="{StaticResource TextPrimary}" />
                                                <Label
                                                    FontSize="12"
                                                    Text="{Binding Medicine.INN}"
                                                    TextColor="{StaticResource TextSecondary}" />
                                            </VerticalStackLayout>
                                        </Grid>

                                        <Border
                                            BackgroundColor="#FFF9C4"
                                            HorizontalOptions="Start"
                                            IsVisible="{Binding EndDate, Converter={StaticResource IsDateExpiredConverter}}"
                                            Margin="0,4,0,0"
                                            Padding="8,2"
                                            StrokeShape="RoundRectangle 8"
                                            StrokeThickness="0">
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="10"
                                                Text="Прошлый курс"
                                                TextColor="#F57F17" />
                                        </Border>

                                        <BoxView
                                            Color="#F0F0F0"
                                            HeightRequest="1"
                                            Margin="0,4" />

                                        <Grid
                                            ColumnDefinitions="100, *"
                                            RowDefinitions="Auto, Auto, Auto"
                                            RowSpacing="6">
                                            <Label
                                                FontSize="13"
                                                Grid.Column="0"
                                                Grid.Row="0"
                                                Text="Дозировка:"
                                                TextColor="{StaticResource TextSecondary}" />
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="13"
                                                Grid.Column="1"
                                                Grid.Row="0"
                                                Text="{Binding Dosage}"
                                                TextColor="{StaticResource TextPrimary}" />

                                            <Label
                                                FontSize="13"
                                                Grid.Column="0"
                                                Grid.Row="1"
                                                Text="Курс:"
                                                TextColor="{StaticResource TextSecondary}" />
                                            <Label
                                                FontSize="13"
                                                Grid.Column="1"
                                                Grid.Row="1"
                                                TextColor="{StaticResource TextPrimary}">
                                                <Label.Text>
                                                    <MultiBinding StringFormat="{}{0:dd MMM} — {1:dd MMM}">
                                                        <Binding Path="StartDate" />
                                                        <Binding Path="EndDate" />
                                                    </MultiBinding>
                                                </Label.Text>
                                            </Label>

                                            <Label
                                                FontSize="13"
                                                Grid.Column="0"
                                                Grid.Row="2"
                                                Text="Врач:"
                                                TextColor="{StaticResource TextSecondary}" />
                                            <Label
                                                FontSize="13"
                                                Grid.Column="1"
                                                Grid.Row="2"
                                                Text="{Binding Doctor.FullName}"
                                                TextColor="{StaticResource TextPrimary}" />
                                        </Grid>

                                        <Border
                                            BackgroundColor="#F5F7FA"
                                            IsVisible="{Binding Notes, Converter={StaticResource StringNotNullOrEmptyConverter}}"
                                            Margin="0,6,0,0"
                                            Padding="12,8"
                                            StrokeShape="RoundRectangle 8"
                                            StrokeThickness="0">
                                            <Label
                                                FontSize="12"
                                                Text="{Binding Notes}"
                                                TextColor="{StaticResource TextSecondary}" />
                                        </Border>

                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </ScrollView>

        </Grid>
    </Grid>
</ContentPage>