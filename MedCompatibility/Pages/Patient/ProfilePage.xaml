<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    BackgroundColor="{StaticResource AppBackground}"
    Shell.NavBarIsVisible="False"
    Title="Профиль"
    x:Class="MedCompatibility.Pages.Patient.ProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Grid>
        <!--  Декоративный фон  -->
        <AbsoluteLayout InputTransparent="True">
            <BoxView
                AbsoluteLayout.LayoutBounds="0.15,0.08,420,420"
                AbsoluteLayout.LayoutFlags="PositionProportional"
                Color="#1A00796B"
                CornerRadius="210"
                HeightRequest="420"
                WidthRequest="420" />
            <BoxView
                AbsoluteLayout.LayoutBounds="0.95,0.30,520,520"
                AbsoluteLayout.LayoutFlags="PositionProportional"
                Color="#140097A7"
                CornerRadius="260"
                HeightRequest="520"
                WidthRequest="520" />
            <BoxView
                AbsoluteLayout.LayoutBounds="0.35,0.98,620,620"
                AbsoluteLayout.LayoutFlags="PositionProportional"
                Color="#0F90A4AE"
                CornerRadius="310"
                HeightRequest="620"
                WidthRequest="620" />
        </AbsoluteLayout>

        <!--  Основная сетка  -->
        <Grid Padding="16,10" RowDefinitions="Auto,*">

            <!--  Шапка  -->
            <Grid
                ColumnDefinitions="48,*,Auto"
                ColumnSpacing="12"
                HeightRequest="60">

                <!--  Назад (Только для врача)  -->
                <Border
                    BackgroundColor="{StaticResource Surface}"
                    Grid.Column="0"
                    HeightRequest="42"
                    HorizontalOptions="Start"
                    IsVisible="{Binding IsDoctor}"
                    StrokeShape="RoundRectangle 12"
                    StrokeThickness="0"
                    WidthRequest="42">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                    </Border.GestureRecognizers>
                    <Border.Shadow>
                        <Shadow
                            Brush="Black"
                            Offset="0,2"
                            Opacity="0.1"
                            Radius="4" />
                    </Border.Shadow>
                    <Label
                        FontSize="26"
                        HorizontalOptions="Center"
                        Margin="0,0,0,4"
                        Text="‹"
                        TextColor="{StaticResource TextPrimary}"
                        VerticalOptions="Center" />
                </Border>

                <!--  Заголовок  -->
                <Label
                    FontAttributes="Bold"
                    FontSize="20"
                    Grid.Column="1"
                    Text="Мой профиль"
                    TextColor="{StaticResource TextPrimary}"
                    VerticalOptions="Center" />

                <!--  Кнопка Выйти  -->
                <Button
                    BackgroundColor="#FFEBEE"
                    Command="{Binding LogoutCommand}"
                    CornerRadius="14"
                    FontAttributes="Bold"
                    FontSize="12"
                    Grid.Column="2"
                    HeightRequest="36"
                    IsVisible="{Binding IsUser}"
                    Padding="12,0"
                    Text="Выйти"
                    TextColor="#D32F2F"
                    VerticalOptions="Center" />
            </Grid>

            <!--  Контент  -->
            <ScrollView Grid.Row="1" Margin="0,10,0,0">
                <VerticalStackLayout
                    HorizontalOptions="Fill"
                    MaximumWidthRequest="600"
                    Spacing="20"
                    VerticalOptions="Start">

                    <!--  Аватар  -->
                    <Border
                        BackgroundColor="{StaticResource Surface}"
                        HeightRequest="100"
                        HorizontalOptions="Center"
                        Stroke="{StaticResource BorderLight}"
                        StrokeShape="RoundRectangle 50"
                        StrokeThickness="1"
                        WidthRequest="100">
                        <Border.Shadow>
                            <Shadow
                                Brush="#90A4AE"
                                Offset="0,6"
                                Opacity="0.15"
                                Radius="15" />
                        </Border.Shadow>
                        <Label
                            FontSize="50"
                            HorizontalOptions="Center"
                            Text="👤"
                            VerticalOptions="Center" />
                    </Border>

                    <!--  Гость  -->
                    <Border
                        BackgroundColor="{StaticResource Surface}"
                        IsVisible="{Binding IsGuest}"
                        Padding="20"
                        Stroke="{StaticResource BorderLight}"
                        StrokeShape="RoundRectangle 20"
                        StrokeThickness="1">
                        <Border.Shadow>
                            <Shadow
                                Brush="#90A4AE"
                                Offset="0,8"
                                Opacity="0.1"
                                Radius="15" />
                        </Border.Shadow>

                        <VerticalStackLayout Spacing="16">
                            <Label
                                FontAttributes="Bold"
                                FontSize="18"
                                HorizontalOptions="Center"
                                Text="Гостевой режим"
                                TextColor="{StaticResource TextPrimary}" />

                            <Label
                                FontSize="14"
                                HorizontalTextAlignment="Center"
                                Text="Войдите в аккаунт, чтобы получить доступ к истории проверок и назначениям врача."
                                TextColor="{StaticResource TextSecondary}" />

                            <Button
                                Command="{Binding GoToLoginCommand}"
                                HeightRequest="48"
                                HorizontalOptions="Fill"
                                Style="{StaticResource PrimaryButton}"
                                Text="Войти или создать аккаунт" />
                        </VerticalStackLayout>
                    </Border>

                    <!--  Пользователь  -->
                    <VerticalStackLayout IsVisible="{Binding IsUser}" Spacing="0">

                        <!--  Просмотр данных  -->
                        <Border
                            BackgroundColor="{StaticResource Surface}"
                            HorizontalOptions="Fill"
                            IsVisible="{Binding IsNotEditing}"
                            Padding="20"
                            Stroke="{StaticResource BorderLight}"
                            StrokeShape="RoundRectangle 20"
                            StrokeThickness="1">
                            <Border.Shadow>
                                <Shadow
                                    Brush="#90A4AE"
                                    Offset="0,8"
                                    Opacity="0.1"
                                    Radius="15" />
                            </Border.Shadow>

                            <VerticalStackLayout Spacing="12">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="20"
                                    HorizontalOptions="Center"
                                    Text="{Binding FullName}"
                                    TextColor="{StaticResource TextPrimary}" />

                                <Label
                                    FontSize="14"
                                    HorizontalOptions="Center"
                                    Text="{Binding RoleName}"
                                    TextColor="{StaticResource Primary}" />

                                <Button
                                    BackgroundColor="Transparent"
                                    Command="{Binding StartEditingCommand}"
                                    FontAttributes="Bold"
                                    FontSize="14"
                                    HorizontalOptions="Center"
                                    Margin="0,10,0,0"
                                    Text="✏️ Редактировать данные"
                                    TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>
                        </Border>

                        <!--  Редактирование  -->
                        <Border
                            BackgroundColor="{StaticResource Surface}"
                            HorizontalOptions="Fill"
                            IsVisible="{Binding IsEditing}"
                            Padding="20"
                            Stroke="{StaticResource BorderLight}"
                            StrokeShape="RoundRectangle 20"
                            StrokeThickness="1">
                            <Border.Shadow>
                                <Shadow
                                    Brush="#90A4AE"
                                    Offset="0,8"
                                    Opacity="0.1"
                                    Radius="15" />
                            </Border.Shadow>

                            <VerticalStackLayout Spacing="16">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="16"
                                    Text="Редактирование профиля"
                                    TextColor="{StaticResource TextPrimary}" />

                                <VerticalStackLayout Spacing="6">
                                    <Label
                                        FontSize="12"
                                        Text="Фамилия"
                                        TextColor="{StaticResource TextSecondary}" />
                                    <Border Style="{StaticResource MedInputContainer}">
                                        <Entry
                                            Placeholder="Введите фамилию"
                                            Text="{Binding EditLastName}"
                                            TextColor="{StaticResource TextPrimary}" />
                                    </Border>
                                </VerticalStackLayout>

                                <VerticalStackLayout Spacing="6">
                                    <Label
                                        FontSize="12"
                                        Text="Имя"
                                        TextColor="{StaticResource TextSecondary}" />
                                    <Border Style="{StaticResource MedInputContainer}">
                                        <Entry
                                            Placeholder="Введите имя"
                                            Text="{Binding EditFirstName}"
                                            TextColor="{StaticResource TextPrimary}" />
                                    </Border>
                                </VerticalStackLayout>

                                <VerticalStackLayout Spacing="6">
                                    <Label
                                        FontSize="12"
                                        Text="Отчество"
                                        TextColor="{StaticResource TextSecondary}" />
                                    <Border Style="{StaticResource MedInputContainer}">
                                        <Entry
                                            Placeholder="Введите отчество"
                                            Text="{Binding EditMiddleName}"
                                            TextColor="{StaticResource TextPrimary}" />
                                    </Border>
                                </VerticalStackLayout>

                                <!--  Кнопки  -->
                                <Grid
                                    ColumnDefinitions="*,*"
                                    ColumnSpacing="12"
                                    HeightRequest="48"
                                    Margin="0,10,0,0">
                                    <Button
                                        Command="{Binding CancelEditingCommand}"
                                        Grid.Column="0"
                                        Margin="0"
                                        Style="{StaticResource SecondaryButton}"
                                        Text="Отмена"
                                        VerticalOptions="Fill" />
                                    <Button
                                        Command="{Binding SaveChangesCommand}"
                                        Grid.Column="1"
                                        Margin="0"
                                        Style="{StaticResource PrimaryButton}"
                                        Text="Сохранить"
                                        VerticalOptions="Fill" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>

                    </VerticalStackLayout>

                    <!--  Отступ снизу  -->
                    <BoxView Color="Transparent" HeightRequest="60" />
                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Grid>
</ContentPage>
