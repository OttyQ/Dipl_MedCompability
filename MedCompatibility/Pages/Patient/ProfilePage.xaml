<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    BackgroundColor="{StaticResource AppBackground}"
    Shell.NavBarIsVisible="False"
    Title="Профиль"
    x:Class="MedCompatibility.Pages.Patient.ProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:controls="clr-namespace:MedCompatibility.Pages.Shared.Controls"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Grid>
        <controls:BackgroundBubblesView />

        <Grid
            HorizontalOptions="{OnPlatform WinUI=Center,
                                           MacCatalyst=Center,
                                           Default=Fill}"
            MaximumWidthRequest="700"
            RowDefinitions="Auto, *"
            WidthRequest="{OnPlatform WinUI=700,
                                      MacCatalyst=700}">

            <controls:CustomHeader
                Grid.Row="0"
                IsBackButtonVisible="{Binding ShowBackButton}"
                Margin="20,20,20,15"
                Title="Мой профиль" />

            <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
                <VerticalStackLayout
                    HorizontalOptions="Fill"
                    Padding="20,0,20,30"
                    Spacing="20">

                    <Border
                        BackgroundColor="{StaticResource Surface}"
                        HeightRequest="100"
                        HorizontalOptions="Center"
                        Stroke="{StaticResource BorderLight}"
                        StrokeShape="RoundRectangle 50"
                        StrokeThickness="1"
                        WidthRequest="100">
                        <Border.Shadow>
                            <Shadow
                                Brush="#90A4AE"
                                Offset="0,6"
                                Opacity="0.15"
                                Radius="15" />
                        </Border.Shadow>
                        <Label
                            FontSize="50"
                            HorizontalOptions="Center"
                            Text="👤"
                            VerticalOptions="Center" />
                    </Border>

                    <Border
                        BackgroundColor="{StaticResource Surface}"
                        HorizontalOptions="Fill"
                        IsVisible="{Binding IsGuest}"
                        Padding="20"
                        Stroke="{StaticResource BorderLight}"
                        StrokeShape="RoundRectangle 20"
                        StrokeThickness="1">
                        <Border.Shadow>
                            <Shadow
                                Brush="#90A4AE"
                                Offset="0,8"
                                Opacity="0.1"
                                Radius="15" />
                        </Border.Shadow>
                        <VerticalStackLayout HorizontalOptions="Fill" Spacing="16">
                            <Label
                                FontAttributes="Bold"
                                FontSize="18"
                                HorizontalOptions="Center"
                                Text="Гостевой режим"
                                TextColor="{StaticResource TextPrimary}" />
                            <Label
                                FontSize="14"
                                HorizontalTextAlignment="Center"
                                Text="Войдите в аккаунт, чтобы получить доступ к истории проверок и назначениям врача."
                                TextColor="{StaticResource TextSecondary}" />
                            <Button
                                Command="{Binding GoToLoginCommand}"
                                HeightRequest="48"
                                HorizontalOptions="Fill"
                                Style="{StaticResource PrimaryButton}"
                                Text="Войти или создать аккаунт" />
                        </VerticalStackLayout>
                    </Border>

                    <VerticalStackLayout
                        HorizontalOptions="Fill"
                        IsVisible="{Binding IsUser}"
                        Spacing="20">

                        <Border
                            BackgroundColor="{StaticResource Surface}"
                            HorizontalOptions="Fill"
                            IsVisible="{Binding IsNotEditing}"
                            Padding="24"
                            Stroke="{StaticResource BorderLight}"
                            StrokeShape="RoundRectangle 24"
                            StrokeThickness="1">
                            <Border.Shadow>
                                <Shadow
                                    Brush="#90A4AE"
                                    Offset="0,8"
                                    Opacity="0.1"
                                    Radius="15" />
                            </Border.Shadow>
                            <VerticalStackLayout HorizontalOptions="Fill" Spacing="12">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="22"
                                    HorizontalOptions="Center"
                                    Text="{Binding FullName}"
                                    TextColor="{StaticResource TextPrimary}" />
                                <Label
                                    FontSize="14"
                                    HorizontalOptions="Center"
                                    Text="{Binding RoleName}"
                                    TextColor="{StaticResource Primary}" />
                                <Button
                                    BackgroundColor="Transparent"
                                    Command="{Binding StartEditingCommand}"
                                    FontAttributes="Bold"
                                    HorizontalOptions="Center"
                                    Text="✏️ Редактировать"
                                    TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>
                        </Border>

                        <Border
                            BackgroundColor="{StaticResource Surface}"
                            HorizontalOptions="Fill"
                            IsVisible="{Binding IsEditing}"
                            Padding="20"
                            Stroke="{StaticResource BorderLight}"
                            StrokeShape="RoundRectangle 24"
                            StrokeThickness="1">
                            <Border.Shadow>
                                <Shadow
                                    Brush="#90A4AE"
                                    Offset="0,8"
                                    Opacity="0.1"
                                    Radius="15" />
                            </Border.Shadow>
                            <VerticalStackLayout HorizontalOptions="Fill" Spacing="18">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="16"
                                    HorizontalOptions="Center"
                                    Text="Данные профиля"
                                    TextColor="{StaticResource TextPrimary}" />

                                <VerticalStackLayout HorizontalOptions="Fill" Spacing="15">
                                    <Border Style="{StaticResource MedInputContainer}">
                                        <Entry
                                            Placeholder="Фамилия"
                                            Text="{Binding EditLastName}"
                                            TextColor="{StaticResource TextPrimary}" />
                                    </Border>
                                    <Border Style="{StaticResource MedInputContainer}">
                                        <Entry
                                            Placeholder="Имя"
                                            Text="{Binding EditFirstName}"
                                            TextColor="{StaticResource TextPrimary}" />
                                    </Border>
                                    <Border Style="{StaticResource MedInputContainer}">
                                        <Entry
                                            Placeholder="Отчество"
                                            Text="{Binding EditMiddleName}"
                                            TextColor="{StaticResource TextPrimary}" />
                                    </Border>
                                </VerticalStackLayout>

                                <Grid
                                    ColumnDefinitions="*,*"
                                    ColumnSpacing="{OnPlatform Android=8,
                                                               iOS=8,
                                                               Default=12}"
                                    HeightRequest="48"
                                    Margin="0,5,0,0">
                                    <Button
                                        Command="{Binding CancelEditingCommand}"
                                        FontSize="{OnPlatform Android=14,
                                                              iOS=14,
                                                              Default=15}"
                                        Grid.Column="0"
                                        Padding="0"
                                        Style="{StaticResource SecondaryButton}"
                                        Text="Отмена"
                                        VerticalOptions="Fill" />
                                    <Button
                                        Command="{Binding SaveChangesCommand}"
                                        FontSize="{OnPlatform Android=14,
                                                              iOS=14,
                                                              Default=15}"
                                        Grid.Column="1"
                                        Padding="0"
                                        Style="{StaticResource PrimaryButton}"
                                        Text="Сохранить"
                                        VerticalOptions="Fill" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>

                        <Button
                            BackgroundColor="#FFEBEE"
                            BorderColor="#D32F2F"
                            BorderWidth="1.5"
                            Command="{Binding LogoutCommand}"
                            CornerRadius="16"
                            FontAttributes="Bold"
                            FontSize="16"
                            HeightRequest="54"
                            HorizontalOptions="Fill"
                            Text="Выйти из аккаунта"
                            TextColor="#D32F2F">
                            <Button.Shadow>
                                <Shadow
                                    Brush="#D32F2F"
                                    Offset="0,4"
                                    Opacity="0.1"
                                    Radius="10" />
                            </Button.Shadow>
                        </Button>

                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Grid>
</ContentPage>