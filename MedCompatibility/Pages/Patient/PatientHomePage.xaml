<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    Shell.NavBarIsVisible="False"
    x:Class="MedCompatibility.Pages.Patient.PatientHomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:controls="clr-namespace:MedCompatibility.Pages.Shared.Controls"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Grid>
        <controls:BackgroundBubblesView />

        <Grid
            HorizontalOptions="{OnPlatform WinUI=Center,
                                           MacCatalyst=Center,
                                           Default=Fill}"
            MaximumWidthRequest="800"
            WidthRequest="{OnPlatform WinUI=800,
                                      MacCatalyst=800}">

            <ScrollView VerticalScrollBarVisibility="Never">
                <VerticalStackLayout Padding="20,20,20,40" Spacing="24">

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                        <VerticalStackLayout Spacing="4">
                            <Label Style="{StaticResource HeaderLabel}" Text="Здравствуйте!" />
                            <Label Style="{StaticResource SubHeaderLabel}" Text="{Binding WelcomeText}" />
                        </VerticalStackLayout>
                        <Button
                            Command="{Binding LogoutCommand}"
                            Grid.Column="1"
                            Style="{StaticResource SecondaryButton}"
                            Text="Выйти"
                            VerticalOptions="Center" />
                    </Grid>

                    <Label
                        FontAttributes="Bold"
                        FontSize="20"
                        Margin="0,8,0,0"
                        Text="Главное меню"
                        TextColor="{StaticResource TextPrimary}" />

                    <Grid
                        ColumnDefinitions="*,*"
                        ColumnSpacing="15"
                        RowDefinitions="Auto,Auto"
                        RowSpacing="15">

                        <controls:ActionTile
                            Command="{Binding GoToScanCommand}"
                            Description="Поиск по штрихкоду"
                            Grid.Column="0"
                            Grid.Row="0"
                            IconBackgroundColor="#2600796B"
                            IconText="🔍"
                            Title="Сканер" />

                        <controls:ActionTile
                            Command="{Binding GoToCompatibilityCommand}"
                            Description="Совместимость препаратов"
                            Grid.Column="1"
                            Grid.Row="0"
                            IconBackgroundColor="#26F9A825"
                            IconText="💊"
                            Title="Проверка" />

                        <controls:ActionTile
                            Command="{Binding GoToHistoryCommand}"
                            Description="Ваши проверки"
                            Grid.Column="0"
                            Grid.Row="1"
                            IconBackgroundColor="#260097A7"
                            IconText="🕒"
                            IsVisible="{Binding IsUser}"
                            Title="История" />

                        <controls:ActionTile
                            Command="{Binding GoToProfileCommand}"
                            Description="Настройки аккаунта"
                            Grid.Column="1"
                            Grid.Row="1"
                            IconBackgroundColor="#2678909C"
                            IconText="👤"
                            IsVisible="{Binding IsUser}"
                            Title="Профиль" />

                    </Grid>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Grid>
</ContentPage>